<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DesktopApp.Views.TasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#0F0F13">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#13131A"
        BorderBrush="#2A2A3A" BorderThickness="0,0,0,1"
        Padding="16,10">
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button x:Name="ManualModeBtn" Content="Manual" Click="ManualMode_Click"
                    Background="#A78BFA" Foreground="White"
                    CornerRadius="6" Padding="12,6"/>
                    <Button x:Name="LinearModeBtn" Content="Linear" Click="LinearMode_Click"
                    Background="Transparent" Foreground="#6B7280"
                    CornerRadius="6" Padding="12,6"/>
                    <Button x:Name="RefreshBtn" Content="Refresh" Click="Refresh_Click"
                    Visibility="Collapsed"
                    Background="#252535" Foreground="#6B7280"
                    CornerRadius="8" Padding="12,6"/>
                    <TextBlock x:Name="StatusText" Foreground="#6B7280"
                       FontSize="12" VerticalAlignment="Center"
                       Visibility="Collapsed"/>
                </StackPanel>
                <Button x:Name="AddTaskBtn" Content="+ New Task" Click="AddTask_Click"
                HorizontalAlignment="Right"
                Background="#252535" Foreground="#A78BFA"
                CornerRadius="8" Padding="12,6"/>
            </Grid>
        </Border>
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal" Spacing="12" Padding="16">

                <Border Width="260" Background="#1A1A24" CornerRadius="12"
            Padding="12" BorderBrush="#2A2A3A" BorderThickness="1"
            VerticalAlignment="Top">
                    <StackPanel Spacing="8">
                        <TextBlock Text="TODO" Foreground="#6B7280"
                       FontSize="11" FontWeight="SemiBold" CharacterSpacing="150"/>
                        <TextBlock x:Name="TodoCount" Text="0" Foreground="#6B7280" FontSize="11"/>
                        <ListView x:Name="TodoList" Background="Transparent"
          SelectionMode="None" ItemClick="Task_Click" IsItemClickEnabled="True" MaxHeight="600">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,4"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#252535" CornerRadius="8"
            Padding="12" BorderBrush="#2A2A3A" BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding IssueIdentifier}" Foreground="#6B7280" FontSize="11"/>
                                            <TextBlock Text="{Binding Title}" Foreground="#E2E8F0" FontSize="13" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Priority}" Foreground="#F59E0B" FontSize="11"/>
                                            <TextBlock Text="{Binding Assignee}" Foreground="#6B7280" FontSize="11"/>
                                            <TextBlock Text="{Binding Labels}" Foreground="#A78BFA" FontSize="11" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Width="260" Background="#1A1A24" CornerRadius="12"
            Padding="12" BorderBrush="#2A2A3A" BorderThickness="1"
            VerticalAlignment="Top">
                    <StackPanel Spacing="8">
                        <TextBlock Text="IN PROGRESS" Foreground="#3B82F6"
                       FontSize="11" FontWeight="SemiBold" CharacterSpacing="150"/>
                        <TextBlock x:Name="InProgressCount" Text="0" Foreground="#6B7280" FontSize="11"/>
                        <ListView x:Name="InProgressList" Background="Transparent"
          SelectionMode="None" ItemClick="Task_Click" IsItemClickEnabled="True" MaxHeight="600">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,4"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#252535" CornerRadius="8"
            Padding="12" BorderBrush="#2A2A3A" BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding IssueIdentifier}" Foreground="#6B7280" FontSize="11"/>
                                            <TextBlock Text="{Binding Title}" Foreground="#E2E8F0" FontSize="13" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Priority}" Foreground="#F59E0B" FontSize="11"/>
                                            <TextBlock Text="{Binding Assignee}" Foreground="#6B7280" FontSize="11"/>
                                            <TextBlock Text="{Binding Labels}" Foreground="#A78BFA" FontSize="11" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Width="260" Background="#1A1A24" CornerRadius="12"
            Padding="12" BorderBrush="#2A2A3A" BorderThickness="1"
            VerticalAlignment="Top">
                    <StackPanel Spacing="8">
                        <TextBlock Text="IN REVIEW" Foreground="#A78BFA"
               FontSize="11" FontWeight="SemiBold" CharacterSpacing="150"/>
                        <TextBlock x:Name="InReviewCount" Text="0" Foreground="#6B7280" FontSize="11"/>
                        <ListView x:Name="InReviewList" Background="Transparent"
          SelectionMode="None" ItemClick="Task_Click" IsItemClickEnabled="True" MaxHeight="600">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,4"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#252535" CornerRadius="8"
            Padding="12" BorderBrush="#2A2A3A" BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding IssueIdentifier}" Foreground="#6B7280" FontSize="11"/>
                                            <TextBlock Text="{Binding Title}" Foreground="#E2E8F0" FontSize="13" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Priority}" Foreground="#F59E0B" FontSize="11"/>
                                            <TextBlock Text="{Binding Assignee}" Foreground="#6B7280" FontSize="11"/>
                                            <TextBlock Text="{Binding Labels}" Foreground="#A78BFA" FontSize="11" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Width="260" Background="#1A1A24" CornerRadius="12"
            Padding="12" BorderBrush="#2A2A3A" BorderThickness="1"
            VerticalAlignment="Top">
                    <StackPanel Spacing="8">
                        <TextBlock Text="DONE" Foreground="#10B981"
                       FontSize="11" FontWeight="SemiBold" CharacterSpacing="150"/>
                        <TextBlock x:Name="DoneCount" Text="0" Foreground="#6B7280" FontSize="11"/>
                        <ListView x:Name="DoneList" Background="Transparent"
          SelectionMode="None" ItemClick="Task_Click" IsItemClickEnabled="True" MaxHeight="600">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,4"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#252535" CornerRadius="8"
            Padding="12" BorderBrush="#2A2A3A" BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding IssueIdentifier}" Foreground="#6B7280" FontSize="11"/>
                                            <TextBlock Text="{Binding Title}" Foreground="#E2E8F0" FontSize="13" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Priority}" Foreground="#F59E0B" FontSize="11"/>
                                            <TextBlock Text="{Binding Assignee}" Foreground="#6B7280" FontSize="11"/>
                                            <TextBlock Text="{Binding Labels}" Foreground="#A78BFA" FontSize="11" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <Border Width="260" Background="#1A1A24" CornerRadius="12"
            Padding="12" BorderBrush="#2A2A3A" BorderThickness="1"
            VerticalAlignment="Top">
                    <StackPanel Spacing="8">
                        <TextBlock Text="BLOCKED" Foreground="#EF4444"
               FontSize="11" FontWeight="SemiBold" CharacterSpacing="150"/>
                        <TextBlock x:Name="BlockedCount" Text="0" Foreground="#6B7280" FontSize="11"/>
                        <ListView x:Name="BlockedList" Background="Transparent"
          SelectionMode="None" ItemClick="Task_Click" IsItemClickEnabled="True" MaxHeight="600">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,4"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#252535" CornerRadius="8"
            Padding="12" BorderBrush="#2A2A3A" BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding IssueIdentifier}" Foreground="#6B7280" FontSize="11"/>
                                            <TextBlock Text="{Binding Title}" Foreground="#E2E8F0" FontSize="13" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Priority}" Foreground="#F59E0B" FontSize="11"/>
                                            <TextBlock Text="{Binding Assignee}" Foreground="#6B7280" FontSize="11"/>
                                            <TextBlock Text="{Binding Labels}" Foreground="#A78BFA" FontSize="11" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>