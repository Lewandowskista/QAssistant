<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="QAssistant.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:tb="using:H.NotifyIcon">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Override Windows accent color to match app purple theme -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <!-- System accent color overrides -->
                    <Color x:Key="SystemAccentColor">#A78BFA</Color>
                    <Color x:Key="SystemAccentColorLight1">#B9A0FB</Color>
                    <Color x:Key="SystemAccentColorLight2">#CBB5FC</Color>
                    <Color x:Key="SystemAccentColorLight3">#DDCAFD</Color>
                    <Color x:Key="SystemAccentColorDark1">#9575E8</Color>
                    <Color x:Key="SystemAccentColorDark2">#8360D6</Color>
                    <Color x:Key="SystemAccentColorDark3">#714BC4</Color>

                    <!-- ToggleSwitch -->
                    <SolidColorBrush x:Key="ToggleSwitchFillOn" Color="#A78BFA"/>
                    <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver" Color="#B9A0FB"/>
                    <SolidColorBrush x:Key="ToggleSwitchFillOnPressed" Color="#8360D6"/>
                    <SolidColorBrush x:Key="ToggleSwitchFillOnDisabled" Color="#3C3255"/>

                    <!-- CheckBox -->
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillChecked" Color="#A78BFA"/>
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPointerOver" Color="#B9A0FB"/>
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedPressed" Color="#8360D6"/>
                    <SolidColorBrush x:Key="CheckBoxCheckBackgroundFillCheckedDisabled" Color="#3C3255"/>

                    <!-- ProgressRing -->
                    <SolidColorBrush x:Key="ProgressRingForegroundThemeBrush" Color="#A78BFA"/>

                    <!-- TextBox / PasswordBox focus border -->
                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#A78BFA"/>

                    <!-- ComboBox -->
                    <SolidColorBrush x:Key="ComboBoxDropDownBackgroundPointerOver" Color="#252535"/>

                    <!-- Hyperlink -->
                    <SolidColorBrush x:Key="HyperlinkButtonForeground" Color="#A78BFA"/>
                    <SolidColorBrush x:Key="HyperlinkButtonForegroundPointerOver" Color="#B9A0FB"/>
                    <SolidColorBrush x:Key="HyperlinkButtonForegroundPressed" Color="#8360D6"/>

                    <!-- ListView / selection -->
                    <SolidColorBrush x:Key="ListAccentLowBrush" Color="#2D2D3F"/>
                    <SolidColorBrush x:Key="ListAccentMediumBrush" Color="#3D3D5F"/>
                    <SolidColorBrush x:Key="ListAccentHighBrush" Color="#A78BFA"/>

                    <!-- App Brushes -->
                    <SolidColorBrush x:Key="ApplicationBackgroundBrush" Color="#0F0F13"/>
                    <SolidColorBrush x:Key="SurfaceBrush" Color="#13131A"/>
                    <SolidColorBrush x:Key="SurfaceVariantBrush" Color="#1A1A24"/>
                    <SolidColorBrush x:Key="BorderBrush" Color="#2A2A3A"/>
                    <SolidColorBrush x:Key="HoverBrush" Color="#252535"/>
                    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E2E8F0"/>
                    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280"/>
                    <SolidColorBrush x:Key="AccentBrush" Color="#A78BFA"/>
                    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="#F59E0B"/>
                    <SolidColorBrush x:Key="SuccessBrush" Color="#10B981"/>
                    <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#252535"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>