<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="QAssistant.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:QAssistant">

    <Grid Background="{ThemeResource ApplicationBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition x:Name="ToolsSidebarColumn" Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- TITLEBAR -->
        <Border Grid.Row="0" Grid.ColumnSpan="3"
        Background="{ThemeResource SurfaceBrush}"
        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Padding="16,0" Height="48">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App name -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                    VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE9D5;" FontSize="13" FontFamily="Segoe Fluent Icons"
                              Foreground="{ThemeResource AccentBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="QAssistant" FontSize="14" FontWeight="SemiBold"
                       Foreground="{ThemeResource AccentBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Drag region -->
                <Border Grid.Column="1" Background="Transparent" x:Name="DragRegion"/>

                <!-- Right controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                    VerticalAlignment="Center" Spacing="0">

                    <!-- Settings button -->
                    <Button x:Name="SettingsBtn"
                        Click="SettingsBtn_Click"
                        Width="32" Height="32"
                        CornerRadius="6"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="Settings">
                        <FontIcon Glyph="&#xE713;" FontSize="14" FontFamily="Segoe Fluent Icons"
                                  Foreground="{ThemeResource TextSecondaryBrush}"/>
                    </Button>

                    <!-- Pin toggle -->
                    <ToggleButton x:Name="PinToggle"
              IsChecked="True"
              Checked="PinToggle_Checked"
              Unchecked="PinToggle_Unchecked"
              Width="64" Height="32"
              CornerRadius="6"
              Margin="0,0,8,0"
              Padding="0"
              BorderThickness="0">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Background" Value="{ThemeResource HoverBrush}"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="CornerRadius" Value="6"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                                                <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                        <TextBlock Text="Pin" FontSize="12"
               FontWeight="SemiBold"
               Foreground="White"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"/>
                    </ToggleButton>

                    <!-- Minimize -->
                    <Button x:Name="MinimizeBtn"
        Click="MinimizeBtn_Click"
        Width="32" Height="32"
        CornerRadius="6"
        Background="Transparent"
        BorderThickness="0"
        Padding="0"
        VerticalAlignment="Center">
                        <TextBlock Text="&#xE921;" 
               FontFamily="Segoe Fluent Icons"
               FontSize="12"
               Foreground="{ThemeResource AccentBrush}"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"/>
                    </Button>

                    <!-- Maximize -->
                    <Button x:Name="MaximizeBtn"
        Click="MaximizeBtn_Click"
        Width="32" Height="32"
        CornerRadius="6"
        Background="Transparent"
        BorderThickness="0"
        Padding="0"
        VerticalAlignment="Center">
                        <TextBlock Text="&#xE922;" 
               FontFamily="Segoe Fluent Icons"
               FontSize="12"
               Foreground="{ThemeResource AccentBrush}"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"/>
                    </Button>

                    <!-- Close -->
                    <Button x:Name="CloseBtn"
        Click="CloseBtn_Click"
        Width="32" Height="32"
        CornerRadius="6"
        Background="Transparent"
        BorderThickness="0"
        Padding="0"
        VerticalAlignment="Center">
                        <TextBlock Text="&#xE8BB;" 
               FontFamily="Segoe Fluent Icons"
               FontSize="12"
               Foreground="{ThemeResource AccentBrush}"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- PROJECTS SIDEBAR -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{ThemeResource SurfaceBrush}"
                BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Projects Header -->
                <Border Grid.Row="0" Padding="12,12,8,8"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1">
                    <TextBlock Text="PROJECTS" Foreground="{ThemeResource TextSecondaryBrush}"
                               FontSize="9" FontWeight="SemiBold" CharacterSpacing="180"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Project List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="4" Padding="8,8">
                        <ListView x:Name="ProjectList"
                                  SelectionChanged="ProjectList_SelectionChanged"
                                  RightTapped="ProjectList_RightTapped"
                                  Background="Transparent"
                                  SelectionMode="Single"
                                  CanReorderItems="True"
                                  CanDragItems="True"
                                  AllowDrop="True"
                                  DragItemsCompleted="ProjectList_DragItemsCompleted">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,2"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <ListViewItemPresenter
                                                    SelectedBackground="{ThemeResource ListAccentLowBrush}"
                                                    SelectedForeground="{ThemeResource TextPrimaryBrush}"
                                                    SelectedPressedBackground="{ThemeResource ListAccentMediumBrush}"
                                                    SelectedPointerOverBackground="{ThemeResource ListAccentMediumBrush}"
                                                    PointerOverBackground="{ThemeResource HoverBrush}"
                                                    PressedBackground="{ThemeResource BorderBrush}"
                                                    CornerRadius="6"
                                                    ContentMargin="10,7"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                        <Border Width="4" Height="16" CornerRadius="2"
                                                Background="{Binding ColorBrush}"/>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="{ThemeResource TextPrimaryBrush}" FontSize="12"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </ScrollViewer>

                <Button Grid.Row="2"
                        Content="+ New Project"
                        Click="AddProject_Click"
                        HorizontalAlignment="Stretch"
                        Margin="8,4,8,12"
                        Background="{ThemeResource HoverBrush}"
                        Foreground="{ThemeResource AccentBrush}"
                        CornerRadius="8"
                        Padding="10,7"/>
            </Grid>
        </Border>

        <!-- TOOLS SIDEBAR -->
        <Border x:Name="ToolsSidebarBorder" Grid.Row="1" Grid.Column="1"
                Background="{ThemeResource SurfaceBrush}"
                BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tools Header with collapse/expand button -->
                <Border x:Name="ToolsHeaderBorder" Grid.Row="0" Padding="12,12,8,8"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock x:Name="ToolsHeaderText" Text="TOOLS" Foreground="{ThemeResource TextSecondaryBrush}"
                                   FontSize="9" FontWeight="SemiBold" CharacterSpacing="180"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="CollapseToolsBtn" Click="CollapseTools_Click"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="Transparent" BorderThickness="0"
                                Padding="6,4" CornerRadius="4"
                                ToolTipService.ToolTip="Collapse sidebar">
                            <FontIcon x:Name="CollapseToolsIcon" Glyph="&#xE76B;" FontSize="11"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource TextSecondaryBrush}"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Navigation Items -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ToolsNavPanel" Spacing="4" Padding="8,8">

                        <!-- Search -->
                        <AutoSuggestBox x:Name="SearchBox"
                            PlaceholderText="Search..."
                            VerticalAlignment="Center"
                            Margin="4,0,4,4"
                            TextChanged="SearchBox_TextChanged"
                            SuggestionChosen="SearchBox_SuggestionChosen"/>

                        <!-- Dashboard -->
                        <Button x:Name="NavDashboard" Click="NavItem_Click" Tag="Dashboard"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                CornerRadius="6" Padding="10,7" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE80F;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Dashboard" FontSize="12"/>
                            </StackPanel>
                        </Button>

                        <!-- Organization Tools -->
                        <TextBlock Text="ORGANIZATION" Foreground="{ThemeResource TextSecondaryBrush}"
                                   FontSize="9" FontWeight="SemiBold" CharacterSpacing="180"
                                   Margin="8,8,0,4"/>
                        <Button x:Name="NavLinks" Click="NavItem_Click" Tag="Links"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="{ThemeResource ListAccentLowBrush}" Foreground="{ThemeResource TextPrimaryBrush}"
                                CornerRadius="6" Padding="10,7" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE71B;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Links" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavNotes" Click="NavItem_Click" Tag="Notes"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                CornerRadius="6" Padding="10,7" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE70B;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Notes" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavFiles" Click="NavItem_Click" Tag="Files"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                CornerRadius="6" Padding="10,7" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE8B7;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Files" FontSize="12"/>
                            </StackPanel>
                        </Button>

                        <!-- QA Basic -->
                        <TextBlock Text="QA BASIC" Foreground="{ThemeResource TextSecondaryBrush}"
                                   FontSize="9" FontWeight="SemiBold" CharacterSpacing="180"
                                   Margin="8,16,0,4"/>
                        <Button x:Name="NavTasks" Click="NavItem_Click" Tag="Tasks"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                CornerRadius="6" Padding="10,7" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE73A;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Tasks" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavTests" Click="NavItem_Click" Tag="Tests"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                CornerRadius="6" Padding="10,7" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE9D5;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Tests" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavTestData" Click="NavItem_Click" Tag="TestData"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                CornerRadius="6" Padding="10,7" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE7C3;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Test Data" FontSize="12"/>
                            </StackPanel>
                        </Button>

                        <!-- QA Advanced -->
                        <TextBlock Text="QA ADVANCED" Foreground="{ThemeResource TextSecondaryBrush}"
                                   FontSize="9" FontWeight="SemiBold" CharacterSpacing="180"
                                   Margin="8,16,0,4"/>
                        <Button x:Name="NavEnvironments" Click="NavItem_Click" Tag="Environments"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                CornerRadius="6" Padding="10,7" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE774;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Environments" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavApi" Click="NavItem_Click" Tag="API"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                CornerRadius="6" Padding="10,7" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE943;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="API" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NavSap" Click="NavItem_Click" Tag="SAP"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                CornerRadius="6" Padding="10,7" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE8EF;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="SAP HAC" FontSize="12"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- MAIN CONTENT AREA -->
        <Grid Grid.Row="1" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Notification Banners -->
            <StackPanel x:Name="NotificationStack" Grid.Row="0"/>

            <!-- Content frame -->
            <Frame Grid.Row="1" x:Name="ContentFrame" Background="{ThemeResource ApplicationBackgroundBrush}"/>
        </Grid>
    </Grid>
</Window>