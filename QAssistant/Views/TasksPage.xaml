<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QAssistant.Views.TasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:QAssistant.Converters"
    Background="{ThemeResource ApplicationBackgroundBrush}"
    KeyDown="Page_KeyDown">

    <Page.Resources>
        <converters:TaskPriorityToBrushConverter x:Key="PriorityColorConverter"/>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{ThemeResource SurfaceBrush}"
                BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button x:Name="ManualModeBtn" Content="Manual" Click="ManualMode_Click"
                            Background="{ThemeResource ListAccentLowBrush}" Foreground="{ThemeResource AccentBrush}"
                            CornerRadius="6" Padding="10,7"/>
                    <Button x:Name="LinearModeBtn" Content="Linear" Click="LinearMode_Click"
                            Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                            CornerRadius="6" Padding="10,7"/>
                    <Button x:Name="JiraModeBtn" Content="Jira" Click="JiraMode_Click"
                            Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                            CornerRadius="6" Padding="10,7"/>
                    <Button x:Name="RefreshBtn" Content="Refresh" Click="Refresh_Click"
                            Visibility="Collapsed"
                            Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource TextSecondaryBrush}"
                            CornerRadius="8" Padding="10,7"/>
                    <TextBlock x:Name="StatusText" Foreground="{ThemeResource TextSecondaryBrush}"
                               FontSize="12" VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                    <Button x:Name="AddTaskBtn" Content="+ New Task" Click="AddTask_Click"
                            Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource AccentBrush}"
                            CornerRadius="8" Padding="10,7"/>
                    <Button x:Name="ShortcutHintBtn" Click="ShortcutHint_Click"
                            Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                            CornerRadius="6" Padding="8,6"
                            ToolTipService.ToolTip="Keyboard shortcuts (Ctrl+/)">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE765;" FontSize="14" FontFamily="Segoe Fluent Icons"/>
                            <Border Background="{ThemeResource HoverBrush}" CornerRadius="4" Padding="6,2"
                                    BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                                <TextBlock Text="Ctrl+/" FontSize="10" Foreground="{ThemeResource TextSecondaryBrush}"
                                           FontFamily="Consolas"/>
                            </Border>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content: Kanban + Detail Panel -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="DetailPanelColumn" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- Kanban Board -->
            <ScrollViewer Grid.Column="0"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" Spacing="12" Padding="16">

                    <!-- BACKLOG -->
                    <Border Width="240" Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="12"
                            Padding="12" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1"
                            VerticalAlignment="Top"
                            AllowDrop="True" Tag="Backlog"
                            DragOver="KanbanColumn_DragOver" Drop="KanbanColumn_Drop">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="BACKLOG" Foreground="#9CA3AF"
                                           FontSize="11" FontWeight="SemiBold" CharacterSpacing="150"/>
                                <Border Background="{ThemeResource HoverBrush}" CornerRadius="8" Padding="6,2">
                                    <TextBlock x:Name="BacklogCount" Text="0" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                </Border>
                            </StackPanel>
                            <ListView x:Name="BacklogList" Background="Transparent"
                                      SelectionMode="None" ItemClick="Task_Click"
                                      IsItemClickEnabled="True" MaxHeight="600"
                                      CanDragItems="True" DragItemsStarting="KanbanList_DragItemsStarting">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,4"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{ThemeResource CardBackgroundBrush}" CornerRadius="8"
                                                Padding="12" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding IssueIdentifier}" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                                <TextBlock Text="{Binding Title}" Foreground="{ThemeResource TextPrimaryBrush}" FontSize="13" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Priority}" Foreground="{Binding Priority, Converter={StaticResource PriorityColorConverter}}" FontSize="11"/>
                                                <TextBlock Text="{Binding Assignee}" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                                <TextBlock Text="{Binding Labels}" Foreground="{ThemeResource AccentBrush}" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- TODO -->
                    <Border Width="240" Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="12"
                            Padding="12" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1"
                            VerticalAlignment="Top"
                            AllowDrop="True" Tag="Todo"
                            DragOver="KanbanColumn_DragOver" Drop="KanbanColumn_Drop">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="TODO" Foreground="{ThemeResource TextSecondaryBrush}"
                                           FontSize="11" FontWeight="SemiBold" CharacterSpacing="150"/>
                                <Border Background="{ThemeResource HoverBrush}" CornerRadius="8" Padding="6,2">
                                    <TextBlock x:Name="TodoCount" Text="0" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                </Border>
                            </StackPanel>
                            <ListView x:Name="TodoList" Background="Transparent"
                                      SelectionMode="None" ItemClick="Task_Click"
                                      IsItemClickEnabled="True" MaxHeight="600"
                                      CanDragItems="True" DragItemsStarting="KanbanList_DragItemsStarting">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,4"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{ThemeResource CardBackgroundBrush}" CornerRadius="8"
                                                Padding="12" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding IssueIdentifier}" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                                <TextBlock Text="{Binding Title}" Foreground="{ThemeResource TextPrimaryBrush}" FontSize="13" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Priority}" Foreground="{Binding Priority, Converter={StaticResource PriorityColorConverter}}" FontSize="11"/>
                                                <TextBlock Text="{Binding Assignee}" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                                <TextBlock Text="{Binding Labels}" Foreground="{ThemeResource AccentBrush}" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- IN PROGRESS -->
                    <Border Width="240" Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="12"
                            Padding="12" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1"
                            VerticalAlignment="Top"
                            AllowDrop="True" Tag="InProgress"
                            DragOver="KanbanColumn_DragOver" Drop="KanbanColumn_Drop">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="IN PROGRESS" Foreground="#3B82F6"
                                           FontSize="11" FontWeight="SemiBold" CharacterSpacing="150"/>
                                <Border Background="{ThemeResource HoverBrush}" CornerRadius="8" Padding="6,2">
                                    <TextBlock x:Name="InProgressCount" Text="0" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                </Border>
                            </StackPanel>
                            <ListView x:Name="InProgressList" Background="Transparent"
                                      SelectionMode="None" ItemClick="Task_Click"
                                      IsItemClickEnabled="True" MaxHeight="600"
                                      CanDragItems="True" DragItemsStarting="KanbanList_DragItemsStarting">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,4"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{ThemeResource CardBackgroundBrush}" CornerRadius="8"
                                                Padding="12" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding IssueIdentifier}" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                                <TextBlock Text="{Binding Title}" Foreground="{ThemeResource TextPrimaryBrush}" FontSize="13" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Priority}" Foreground="{Binding Priority, Converter={StaticResource PriorityColorConverter}}" FontSize="11"/>
                                                <TextBlock Text="{Binding Assignee}" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                                <TextBlock Text="{Binding Labels}" Foreground="{ThemeResource AccentBrush}" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- IN REVIEW -->
                    <Border Width="240" Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="12"
                            Padding="12" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1"
                            VerticalAlignment="Top"
                            AllowDrop="True" Tag="InReview"
                            DragOver="KanbanColumn_DragOver" Drop="KanbanColumn_Drop">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="IN REVIEW" Foreground="#A78BFA"
                                           FontSize="11" FontWeight="SemiBold" CharacterSpacing="150"/>
                                <Border Background="{ThemeResource HoverBrush}" CornerRadius="8" Padding="6,2">
                                    <TextBlock x:Name="InReviewCount" Text="0" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                </Border>
                            </StackPanel>
                            <ListView x:Name="InReviewList" Background="Transparent"
                                      SelectionMode="None" ItemClick="Task_Click"
                                      IsItemClickEnabled="True" MaxHeight="600"
                                      CanDragItems="True" DragItemsStarting="KanbanList_DragItemsStarting">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,4"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{ThemeResource CardBackgroundBrush}" CornerRadius="8"
                                                Padding="12" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding IssueIdentifier}" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                                <TextBlock Text="{Binding Title}" Foreground="{ThemeResource TextPrimaryBrush}" FontSize="13" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Priority}" Foreground="{Binding Priority, Converter={StaticResource PriorityColorConverter}}" FontSize="11"/>
                                                <TextBlock Text="{Binding Assignee}" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                                <TextBlock Text="{Binding Labels}" Foreground="{ThemeResource AccentBrush}" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- DONE -->
                    <Border Width="240" Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="12"
                            Padding="12" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1"
                            VerticalAlignment="Top"
                            AllowDrop="True" Tag="Done"
                            DragOver="KanbanColumn_DragOver" Drop="KanbanColumn_Drop">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="DONE" Foreground="#10B981"
                                           FontSize="11" FontWeight="SemiBold" CharacterSpacing="150"/>
                                <Border Background="{ThemeResource HoverBrush}" CornerRadius="8" Padding="6,2">
                                    <TextBlock x:Name="DoneCount" Text="0" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                </Border>
                            </StackPanel>
                            <ListView x:Name="DoneList" Background="Transparent"
                                      SelectionMode="None" ItemClick="Task_Click"
                                      IsItemClickEnabled="True" MaxHeight="600"
                                      CanDragItems="True" DragItemsStarting="KanbanList_DragItemsStarting">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,4"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{ThemeResource CardBackgroundBrush}" CornerRadius="8"
                                                Padding="12" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding IssueIdentifier}" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                                <TextBlock Text="{Binding Title}" Foreground="{ThemeResource TextPrimaryBrush}" FontSize="13" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Priority}" Foreground="{Binding Priority, Converter={StaticResource PriorityColorConverter}}" FontSize="11"/>
                                                <TextBlock Text="{Binding Assignee}" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                                <TextBlock Text="{Binding Labels}" Foreground="{ThemeResource AccentBrush}" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- CANCELED -->
                    <Border Width="240" Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="12"
                            Padding="12" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1"
                            VerticalAlignment="Top"
                            AllowDrop="True" Tag="Canceled"
                            DragOver="KanbanColumn_DragOver" Drop="KanbanColumn_Drop">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="CANCELED" Foreground="#EF4444"
                                           FontSize="11" FontWeight="SemiBold" CharacterSpacing="150"/>
                                <Border Background="{ThemeResource HoverBrush}" CornerRadius="8" Padding="6,2">
                                    <TextBlock x:Name="CanceledCount" Text="0" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                </Border>
                            </StackPanel>
                            <ListView x:Name="CanceledList" Background="Transparent"
                                      SelectionMode="None" ItemClick="Task_Click"
                                      IsItemClickEnabled="True" MaxHeight="600"
                                      CanDragItems="True" DragItemsStarting="KanbanList_DragItemsStarting">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,4"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{ThemeResource CardBackgroundBrush}" CornerRadius="8"
                                                Padding="12" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding IssueIdentifier}" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                                <TextBlock Text="{Binding Title}" Foreground="{ThemeResource TextPrimaryBrush}" FontSize="13" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Priority}" Foreground="{Binding Priority, Converter={StaticResource PriorityColorConverter}}" FontSize="11"/>
                                                <TextBlock Text="{Binding Assignee}" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                                <TextBlock Text="{Binding Labels}" Foreground="{ThemeResource AccentBrush}" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- DUPLICATE -->
                    <Border Width="240" Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="12"
                            Padding="12" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1"
                            VerticalAlignment="Top"
                            AllowDrop="True" Tag="Duplicate"
                            DragOver="KanbanColumn_DragOver" Drop="KanbanColumn_Drop">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="DUPLICATE" Foreground="#F59E0B"
                                           FontSize="11" FontWeight="SemiBold" CharacterSpacing="150"/>
                                <Border Background="{ThemeResource HoverBrush}" CornerRadius="8" Padding="6,2">
                                    <TextBlock x:Name="DuplicateCount" Text="0" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                </Border>
                            </StackPanel>
                            <ListView x:Name="DuplicateList" Background="Transparent"
                                      SelectionMode="None" ItemClick="Task_Click"
                                      IsItemClickEnabled="True" MaxHeight="600"
                                      CanDragItems="True" DragItemsStarting="KanbanList_DragItemsStarting">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,4"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{ThemeResource CardBackgroundBrush}" CornerRadius="8"
                                                Padding="12" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding IssueIdentifier}" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                                <TextBlock Text="{Binding Title}" Foreground="{ThemeResource TextPrimaryBrush}" FontSize="13" TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Priority}" Foreground="{Binding Priority, Converter={StaticResource PriorityColorConverter}}" FontSize="11"/>
                                                <TextBlock Text="{Binding Assignee}" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                                <TextBlock Text="{Binding Labels}" Foreground="{ThemeResource AccentBrush}" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Detail Panel -->
            <Border Grid.Column="1" Background="{ThemeResource SurfaceBrush}"
                    BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Padding="20,16"
                            BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel Spacing="4">
                                <TextBlock x:Name="DetailIdentifier"
                                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                <TextBlock x:Name="DetailTitle"
                                           Foreground="{ThemeResource TextPrimaryBrush}" FontSize="16"
                                           FontWeight="SemiBold" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                                    <Border x:Name="DetailStatusBadge" CornerRadius="4" Padding="8,3">
                                        <TextBlock x:Name="DetailStatus" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                    <Border CornerRadius="4" Padding="8,3" Background="#2D2010">
                                        <TextBlock x:Name="DetailPriority" Foreground="{ThemeResource AccentSecondaryBrush}" FontSize="11"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                            <Button Click="CloseDetail_Click"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{ThemeResource TextSecondaryBrush}" Padding="8,4">
                                <FontIcon Glyph="&#xE711;" FontSize="12" FontFamily="Segoe Fluent Icons"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Tab Bar -->
                    <Border Grid.Row="1" Background="{ThemeResource ApplicationBackgroundBrush}"
                            BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Spacing="0">
                            <Button x:Name="TabDescription" Content="Description"
                                    Click="TabDescription_Click"
                                    Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource AccentBrush}"
                                    BorderThickness="0,0,0,2" BorderBrush="{ThemeResource AccentBrush}"
                                    CornerRadius="0" Padding="16,10" FontSize="12"/>
                            <Button x:Name="TabDetails" Content="Details"
                                    Click="TabDetails_Click"
                                    Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                    BorderThickness="0" CornerRadius="0"
                                    Padding="16,10" FontSize="12"/>
                            <Button x:Name="TabComments" Content="Comments"
                                    Click="TabComments_Click"
                                    Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                    BorderThickness="0" CornerRadius="0"
                                    Padding="16,10" FontSize="12"/>
                            <Button x:Name="TabHistory" Content="History"
                                    Click="TabHistory_Click"
                                    Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                    BorderThickness="0" CornerRadius="0"
                                    Padding="16,10" FontSize="12"/>
                            <Button x:Name="TabWorklog" Content="Worklog"
                                    Click="TabWorklog_Click"
                                    Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                    BorderThickness="0" CornerRadius="0"
                                    Padding="16,10" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <!-- Tab Content -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <Grid>

                            <!-- Details Tab -->
                            <StackPanel x:Name="DetailsTab" Spacing="16" Padding="20,16" Visibility="Collapsed">
                                <StackPanel Spacing="8">
                                    <StackPanel x:Name="DetailAssigneePanel" Orientation="Horizontal"
                                                Spacing="8" Visibility="Collapsed">
                                        <TextBlock Text="Assignee" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" Width="80"/>
                                        <TextBlock x:Name="DetailAssignee" Foreground="{ThemeResource TextPrimaryBrush}" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel x:Name="DetailDueDatePanel" Orientation="Horizontal"
                                                Spacing="8" Visibility="Collapsed">
                                        <TextBlock Text="Due Date" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" Width="80"/>
                                        <TextBlock x:Name="DetailDueDate" Foreground="{ThemeResource TextPrimaryBrush}" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel x:Name="DetailLabelsPanel" Orientation="Horizontal"
                                                Spacing="8" Visibility="Collapsed">
                                        <TextBlock Text="Labels" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" Width="80"/>
                                        <TextBlock x:Name="DetailLabels" Foreground="{ThemeResource AccentBrush}" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Linear task info -->
                                <StackPanel x:Name="LinearTaskInfo" Spacing="12" Visibility="Collapsed">
                                    <Border Height="1" Background="{ThemeResource BorderBrush}"/>
                                    <TextBlock Text="ISSUE DETAILS" Foreground="{ThemeResource TextSecondaryBrush}"
                                               FontSize="9" FontWeight="SemiBold" CharacterSpacing="180"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Source" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" Width="80"/>
                                        <TextBlock Text="Linear" Foreground="{ThemeResource TextPrimaryBrush}" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Identifier" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" Width="80"/>
                                        <TextBlock x:Name="LinearDetailIdentifier" Foreground="{ThemeResource TextPrimaryBrush}" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Status" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" Width="80"/>
                                        <TextBlock x:Name="LinearDetailStatus" Foreground="{ThemeResource TextPrimaryBrush}" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Priority" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" Width="80"/>
                                        <TextBlock x:Name="LinearDetailPriority" Foreground="{ThemeResource AccentSecondaryBrush}" FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Jira task info -->
                                <StackPanel x:Name="JiraTaskInfo" Spacing="12" Visibility="Collapsed">
                                    <Border Height="1" Background="{ThemeResource BorderBrush}"/>
                                    <TextBlock Text="ISSUE DETAILS" Foreground="{ThemeResource TextSecondaryBrush}"
                                               FontSize="9" FontWeight="SemiBold" CharacterSpacing="180"/>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Source" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" Width="80"/>
                                        <TextBlock Text="Jira" Foreground="{ThemeResource TextPrimaryBrush}" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Identifier" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" Width="80"/>
                                        <TextBlock x:Name="JiraDetailIdentifier" Foreground="{ThemeResource TextPrimaryBrush}" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Status" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" Width="80"/>
                                        <TextBlock x:Name="JiraDetailStatus" Foreground="{ThemeResource TextPrimaryBrush}" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="Priority" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" Width="80"/>
                                        <TextBlock x:Name="JiraDetailPriority" Foreground="{ThemeResource AccentSecondaryBrush}" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel x:Name="JiraIssueTypePanel" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
                                        <TextBlock Text="Type" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" Width="80"/>
                                        <TextBlock x:Name="JiraDetailIssueType" Foreground="{ThemeResource TextPrimaryBrush}" FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Manual task fields -->
                                <StackPanel x:Name="ManualTaskFields" Spacing="12" Visibility="Collapsed">
                                    <Border Height="1" Background="{ThemeResource BorderBrush}"/>
                                    <TextBlock Text="EDIT TASK" Foreground="{ThemeResource TextSecondaryBrush}"
                                               FontSize="9" FontWeight="SemiBold" CharacterSpacing="180"/>
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Status" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                                        <ComboBox x:Name="DetailStatusPicker"
                                                  HorizontalAlignment="Stretch"
                                                  Background="{ThemeResource ApplicationBackgroundBrush}"
                                                  Foreground="{ThemeResource TextPrimaryBrush}"
                                                  BorderBrush="{ThemeResource BorderBrush}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="Priority" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                                        <ComboBox x:Name="DetailPriorityPicker"
                                                  HorizontalAlignment="Stretch"
                                                  Background="{ThemeResource ApplicationBackgroundBrush}"
                                                  Foreground="{ThemeResource TextPrimaryBrush}"
                                                  BorderBrush="{ThemeResource BorderBrush}"/>
                                    </StackPanel>
                                    <StackPanel Spacing="6">
                                        <CheckBox x:Name="DetailSetDueDate" Content="Set due date"
                                                  Foreground="{ThemeResource TextPrimaryBrush}"
                                                  Checked="DetailSetDueDate_Checked"
                                                  Unchecked="DetailSetDueDate_Unchecked"/>
                                        <StackPanel x:Name="DetailDateTimePicker" Spacing="8" Visibility="Collapsed">
                                            <DatePicker x:Name="DetailDueDatePicker"
                                                        HorizontalAlignment="Stretch"/>
                                            <TimePicker x:Name="DetailDueTimePicker"
                                                        HorizontalAlignment="Stretch"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- Description Tab -->
                            <StackPanel x:Name="DescriptionTab" Spacing="16"
                                        Padding="20,16">
                                <RichTextBlock x:Name="DetailDescription"
                                               Foreground="{ThemeResource TextPrimaryBrush}" FontSize="13"
                                               TextWrapping="Wrap" LineHeight="22"/>
                                <StackPanel x:Name="MediaSection" Spacing="8" Visibility="Collapsed">
                                    <Border Height="1" Background="{ThemeResource BorderBrush}"/>
                                    <TextBlock Text="MEDIA" Foreground="{ThemeResource TextSecondaryBrush}"
                                               FontSize="9" FontWeight="SemiBold" CharacterSpacing="180"/>
                                    <StackPanel x:Name="MediaContainer" Spacing="8"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Comments Tab -->
                            <StackPanel x:Name="CommentsTab" Spacing="12"
                                        Padding="20,16" Visibility="Collapsed">
                                <StackPanel x:Name="CommentsContainer" Spacing="12"/>
                                <StackPanel x:Name="LinearCommentFields" Spacing="8" Visibility="Collapsed">
                                    <Border Height="1" Background="{ThemeResource BorderBrush}"/>
                                    <TextBlock Text="ADD COMMENT" Foreground="{ThemeResource TextSecondaryBrush}"
                                               FontSize="9" FontWeight="SemiBold" CharacterSpacing="180"/>
                                    <TextBox x:Name="DetailCommentBox"
                                             PlaceholderText="Write a comment..."
                                             AcceptsReturn="True" Height="80"
                                             TextWrapping="Wrap"
                                             Background="{ThemeResource ApplicationBackgroundBrush}"
                                             Foreground="{ThemeResource TextPrimaryBrush}"
                                             BorderBrush="{ThemeResource BorderBrush}"
                                             CornerRadius="8"
                                             Padding="12"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- History Tab -->
                            <StackPanel x:Name="HistoryTab" Spacing="12"
                                        Padding="20,16" Visibility="Collapsed">
                                <StackPanel x:Name="HistoryContainer" Spacing="12"/>
                            </StackPanel>

                            <!-- Worklog Tab -->
                            <StackPanel x:Name="WorklogTab" Spacing="12"
                                        Padding="20,16" Visibility="Collapsed">
                                <StackPanel x:Name="WorklogContainer" Spacing="12"/>
                            </StackPanel>

                        </Grid>
                    </ScrollViewer>

                    <!-- Footer Actions -->
                    <Border Grid.Row="3" Padding="20,12"
                            BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,1,0,0"
                            Background="{ThemeResource ApplicationBackgroundBrush}">
                        <StackPanel Spacing="8">
                            <!-- Analyze button (top, full width) -->
                            <Button x:Name="DetailAnalyzeBtn" Content="Analyze" Click="AnalyzeIssue_Click"
                                    HorizontalAlignment="Stretch"
                                    Background="{ThemeResource AccentBrush}" Foreground="White"
                                    CornerRadius="8" Padding="14,8"/>
                            <!-- Bug Report button -->
                            <Button x:Name="BugReportBtn" Click="BugReport_Click"
                                    HorizontalAlignment="Stretch"
                                    Background="#1E2A1E" Foreground="#34D399"
                                    BorderBrush="#2A4A2A" BorderThickness="1"
                                    CornerRadius="8" Padding="14,8">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE768;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                    <TextBlock Text="Generate Bug Report" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <!-- Manual actions -->
                            <StackPanel x:Name="ManualActions" Orientation="Horizontal"
                                        Spacing="8" Visibility="Collapsed">
                                <Button Content="Save Changes" Click="SaveTaskChanges_Click"
                                        Background="{ThemeResource AccentBrush}" Foreground="White"
                                        CornerRadius="8" Padding="14,8"/>
                                <Button Content="Delete" Click="DeleteTask_Click"
                                        Background="#3F1A1A" Foreground="#F87171"
                                        CornerRadius="8" Padding="14,8"/>
                            </StackPanel>
                            <!-- Linear actions - two buttons side by side, each half width, aligned with Analyze button -->
                            <Grid x:Name="LinearActions" HorizontalAlignment="Stretch" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Post Comment" Click="PostComment_Click"
                                        HorizontalAlignment="Stretch"
                                        Background="{ThemeResource AccentBrush}" Foreground="White"
                                        CornerRadius="8" Padding="14,8" Margin="0,0,4,0"/>
                                <Button Grid.Column="2" Content="Open in Linear" Click="OpenInLinear_Click"
                                        HorizontalAlignment="Stretch"
                                        Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource TextSecondaryBrush}"
                                        CornerRadius="8" Padding="14,8" Margin="4,0,0,0"/>
                            </Grid>
                            <!-- Jira actions -->
                            <Grid x:Name="JiraActions" HorizontalAlignment="Stretch" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Post Comment" Click="PostJiraComment_Click"
                                        HorizontalAlignment="Stretch"
                                        Background="{ThemeResource AccentBrush}" Foreground="White"
                                        CornerRadius="8" Padding="14,8" Margin="0,0,4,0"/>
                                <Button Grid.Column="2" Content="Open in Jira" Click="OpenInJira_Click"
                                        HorizontalAlignment="Stretch"
                                        Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource TextSecondaryBrush}"
                                        CornerRadius="8" Padding="14,8" Margin="4,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Busy / Loading Overlay (used instead of a ContentDialog to avoid modal issues) -->
        <Grid x:Name="BusyOverlay" Visibility="Collapsed" Grid.Row="0" Grid.RowSpan="2"
              Background="#80000000">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="12" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Background="{ThemeResource SurfaceBrush}" Padding="20" CornerRadius="12">
                    <ProgressRing IsActive="True" Width="48" Height="48"/>
                    <TextBlock Text="Gemini is analyzing the issue..."
                               Foreground="{ThemeResource TextSecondaryBrush}" FontSize="13" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Media Lightbox Overlay -->
        <Grid x:Name="LightboxOverlay" Visibility="Collapsed"
              Background="#CC000000" Grid.RowSpan="2">
            <Grid HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  Margin="40"
                  Background="{ThemeResource SurfaceBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Lightbox Header -->
                <Border Grid.Row="0" Padding="16,12"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="Media Viewer" Foreground="{ThemeResource TextPrimaryBrush}"
                                   FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <Button Click="CloseLightbox_Click"
                                HorizontalAlignment="Right"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{ThemeResource TextSecondaryBrush}" Padding="8,4">
                            <FontIcon Glyph="&#xE711;" FontSize="12" FontFamily="Segoe Fluent Icons"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Lightbox Image -->
                <ScrollViewer Grid.Row="1"
                              ZoomMode="Enabled"
                              MinZoomFactor="0.25"
                              MaxZoomFactor="4.0"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Padding="16">
                    <Image x:Name="LightboxImage"
                           Stretch="Uniform"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"/>
                </ScrollViewer>

                <!-- Lightbox Footer -->
                <Border Grid.Row="2" Padding="16,10"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,1,0,0"
                        Background="{ThemeResource ApplicationBackgroundBrush}">
                    <Button Content="Open in Browser" Click="LightboxOpenBrowser_Click"
                            HorizontalAlignment="Right"
                            Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource AccentBrush}"
                            CornerRadius="8" Padding="14,8"/>
                </Border>
            </Grid>
        </Grid>

        <!-- Rate-limit notification banner -->
        <Border x:Name="RateLimitBanner" Visibility="Collapsed"
                Grid.Row="0" Grid.RowSpan="2"
                VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Margin="0,0,0,16"
                Background="#3C1414" BorderBrush="{ThemeResource ErrorBrush}" BorderThickness="1"
                CornerRadius="8" Padding="16,10">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE7BA;" FontSize="14"
                          Foreground="{ThemeResource ErrorBrush}" VerticalAlignment="Center"/>
                <TextBlock x:Name="RateLimitText"
                           Text="All AI models are currently rate-limited. Please try again later."
                           Foreground="#FCA5A5" FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Keyboard Shortcuts Overlay -->
        <Grid x:Name="ShortcutOverlay" Visibility="Collapsed" Grid.RowSpan="2"
              Background="#99000000">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Column="1" Grid.Row="1"
                    Background="{ThemeResource SurfaceBrush}" CornerRadius="16"
                    BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1"
                    Padding="0" MinWidth="420" MaxWidth="500">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Overlay Header -->
                    <Border Grid.Row="0" Padding="24,20,24,12"
                            BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE765;" FontSize="18" FontFamily="Segoe Fluent Icons"
                                              Foreground="{ThemeResource AccentBrush}"/>
                                    <TextBlock Text="Keyboard Shortcuts" Foreground="{ThemeResource TextPrimaryBrush}"
                                               FontSize="16" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Speed up your workflow with these shortcuts"
                                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" Margin="28,0,0,0"/>
                            </StackPanel>
                            <Button Click="CloseShortcutOverlay_Click"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{ThemeResource TextSecondaryBrush}" Padding="6,4" CornerRadius="6">
                                <FontIcon Glyph="&#xE711;" FontSize="11" FontFamily="Segoe Fluent Icons"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Shortcut Groups -->
                    <StackPanel Grid.Row="1" Spacing="20" Padding="24,20">

                        <!-- Board Navigation -->
                        <StackPanel Spacing="10">
                            <TextBlock Text="BOARD" Foreground="{ThemeResource AccentBrush}"
                                       FontSize="9" FontWeight="SemiBold" CharacterSpacing="180"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Grid.Column="0" Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="5"
                                        Padding="8,4" Margin="0,0,16,8" HorizontalAlignment="Left"
                                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                                    <TextBlock Text="Ctrl + 1" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextPrimaryBrush}"/>
                                </Border>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Switch to Manual mode"
                                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,8"/>

                                <Border Grid.Row="1" Grid.Column="0" Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="5"
                                        Padding="8,4" Margin="0,0,16,8" HorizontalAlignment="Left"
                                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                                    <TextBlock Text="Ctrl + 2" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextPrimaryBrush}"/>
                                </Border>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Switch to Linear mode"
                                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,8"/>

                                <Border Grid.Row="2" Grid.Column="0" Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="5"
                                        Padding="8,4" Margin="0,0,16,8" HorizontalAlignment="Left"
                                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                                    <TextBlock Text="Ctrl + 3" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextPrimaryBrush}"/>
                                </Border>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Switch to Jira mode"
                                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,8"/>

                                <Border Grid.Row="3" Grid.Column="0" Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="5"
                                        Padding="8,4" Margin="0,0,16,0" HorizontalAlignment="Left"
                                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                                    <TextBlock Text="Ctrl + R" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextPrimaryBrush}"/>
                                </Border>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="Refresh issues"
                                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <Border Height="1" Background="{ThemeResource BorderBrush}"/>

                        <!-- Task Actions -->
                        <StackPanel Spacing="10">
                            <TextBlock Text="TASKS" Foreground="{ThemeResource AccentBrush}"
                                       FontSize="9" FontWeight="SemiBold" CharacterSpacing="180"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Grid.Column="0" Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="5"
                                        Padding="8,4" Margin="0,0,16,8" HorizontalAlignment="Left"
                                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                                    <TextBlock Text="Ctrl + N" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextPrimaryBrush}"/>
                                </Border>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Create new task"
                                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,8"/>

                                <Border Grid.Row="1" Grid.Column="0" Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="5"
                                        Padding="8,4" Margin="0,0,16,8" HorizontalAlignment="Left"
                                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                                    <TextBlock Text="Ctrl + S" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextPrimaryBrush}"/>
                                </Border>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Save task changes"
                                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,8"/>

                                <Border Grid.Row="2" Grid.Column="0" Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="5"
                                        Padding="8,4" Margin="0,0,16,8" HorizontalAlignment="Left"
                                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                                    <TextBlock Text="Ctrl + D" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextPrimaryBrush}"/>
                                </Border>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Delete selected task"
                                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,8"/>

                                <Border Grid.Row="3" Grid.Column="0" Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="5"
                                        Padding="8,4" Margin="0,0,16,0" HorizontalAlignment="Left"
                                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                                    <TextBlock Text="Ctrl + O" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextPrimaryBrush}"/>
                                </Border>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="Open task in Linear"
                                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                        <Border Height="1" Background="{ThemeResource BorderBrush}"/>

                        <!-- General -->
                        <StackPanel Spacing="10">
                            <TextBlock Text="GENERAL" Foreground="{ThemeResource AccentBrush}"
                                       FontSize="9" FontWeight="SemiBold" CharacterSpacing="180"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Grid.Column="0" Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="5"
                                        Padding="8,4" Margin="0,0,16,8" HorizontalAlignment="Left"
                                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                                    <TextBlock Text="Esc" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextPrimaryBrush}"/>
                                </Border>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Close panel / overlay / lightbox"
                                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,0,8"/>

                                <Border Grid.Row="1" Grid.Column="0" Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="5"
                                        Padding="8,4" Margin="0,0,16,0" HorizontalAlignment="Left"
                                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                                    <TextBlock Text="Ctrl + /" FontFamily="Consolas" FontSize="12" Foreground="{ThemeResource TextPrimaryBrush}"/>
                                </Border>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Toggle this shortcuts panel"
                                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>

                    </StackPanel>

                    <!-- Overlay Footer -->
                    <Border Grid.Row="2" Padding="24,14"
                            BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,1,0,0"
                            Background="{ThemeResource ApplicationBackgroundBrush}" CornerRadius="0,0,16,16">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
                            <TextBlock Text="Press" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                            <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="4" Padding="6,2"
                                    BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                                <TextBlock Text="Esc" FontFamily="Consolas" FontSize="10" Foreground="{ThemeResource TextSecondaryBrush}"/>
                            </Border>
                            <TextBlock Text="to close" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                        </StackPanel>
                    </Border>

                </Grid>
            </Border>
        </Grid>

    </Grid>
</Page>

