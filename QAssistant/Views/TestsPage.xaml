<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QAssistant.Views.TestsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar with subtabs -->
        <Border Grid.Row="0" Background="{ThemeResource SurfaceBrush}"
                BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button x:Name="TestCaseGenBtn" Content="Test Case Generation" Click="SubTab_Click" Tag="TestCaseGeneration"
                            Background="{ThemeResource ListAccentLowBrush}" Foreground="{ThemeResource AccentBrush}"
                            CornerRadius="6" Padding="10,7"/>
                    <Button x:Name="TestRunsBtn" Content="Test Runs" Click="SubTab_Click" Tag="TestRuns"
                            Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                            CornerRadius="6" Padding="10,7"/>
                    <Button x:Name="ReportsBtn" Content="Reports" Click="SubTab_Click" Tag="Reports"
                            Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                            CornerRadius="6" Padding="10,7"/>
                    <Button x:Name="CoverageMatrixBtn" Content="Coverage Matrix" Click="SubTab_Click" Tag="CoverageMatrix"
                            Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                            CornerRadius="6" Padding="10,7"/>
                    <Button x:Name="RegressionBuilderBtn" Content="Regression Builder" Click="SubTab_Click" Tag="RegressionBuilder"
                            Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                            CornerRadius="6" Padding="10,7"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Subtab content area -->
        <Grid Grid.Row="1">

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- Test Case Generation panel                         -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Grid x:Name="TestCaseGenerationPanel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Primary — source, generate, archive toggle -->
                <Border Grid.Row="0" Background="{ThemeResource SurfaceBrush}"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="16,10">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <TextBlock Text="SOURCE" Foreground="{ThemeResource TextSecondaryBrush}"
                                       FontSize="10" FontWeight="SemiBold"
                                       CharacterSpacing="150" VerticalAlignment="Center"/>
                            <ComboBox x:Name="SourcePicker"
                                      SelectedIndex="0"
                                      Background="#252535" Foreground="#E2E8F0"
                                      BorderBrush="#2A2A3A" CornerRadius="8"
                                      MinWidth="120">
                                <ComboBoxItem Content="Linear" Tag="Linear"/>
                                <ComboBoxItem Content="Jira" Tag="Jira"/>
                            </ComboBox>
                            <Button x:Name="GenerateBtn" Content="Generate Test Cases"
                                    Click="GenerateTestCases_Click"
                                    Background="{ThemeResource AccentBrush}" Foreground="White"
                                    CornerRadius="8" Padding="10,7"/>
                            <TextBlock x:Name="GenerationStatusText"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="VIEW"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       FontSize="10" FontWeight="SemiBold"
                                       CharacterSpacing="150" VerticalAlignment="Center"/>
                            <ComboBox x:Name="TestCaseViewPicker"
                                      SelectedIndex="0"
                                      Background="#252535" Foreground="#E2E8F0"
                                      BorderBrush="#2A2A3A" CornerRadius="8"
                                      MinWidth="160"
                                      SelectionChanged="TestCaseViewPicker_Changed">
                                <ComboBoxItem Content="All Plans" Tag="AllPlans"/>
                                <ComboBoxItem Content="Regression Suites" Tag="RegressionSuites"/>
                            </ComboBox>
                            <ToggleButton x:Name="ShowArchivedToggle" Content="Show Archived"
                                          Click="ShowArchivedToggle_Click"
                                          Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                          BorderBrush="{ThemeResource BorderBrush}" CornerRadius="6"
                                          Padding="10,7" FontSize="11"/>
                            <TextBlock x:Name="TestCaseCountText"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Row 1: Secondary — import, design doc, clear -->
                <Border Grid.Row="1" Background="{ThemeResource SurfaceBrush}"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="16,6">
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="SOURCE" Foreground="{ThemeResource TextSecondaryBrush}"
                                   FontSize="10" FontWeight="SemiBold" CharacterSpacing="150"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="SourceFilterAllBtn" Content="All" Tag="All"
                                Click="SourceFilter_Click"
                                Background="{ThemeResource ListAccentLowBrush}"
                                Foreground="{ThemeResource AccentBrush}"
                                BorderThickness="0" CornerRadius="6" Padding="8,5" FontSize="11"/>
                        <Button x:Name="SourceFilterJiraBtn" Content="Jira" Tag="Jira"
                                Click="SourceFilter_Click"
                                Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                BorderThickness="0" CornerRadius="6" Padding="8,5" FontSize="11"/>
                        <Button x:Name="SourceFilterLinearBtn" Content="Linear" Tag="Linear"
                                Click="SourceFilter_Click"
                                Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                BorderThickness="0" CornerRadius="6" Padding="8,5" FontSize="11"/>
                        <Button x:Name="SourceFilterManualBtn" Content="Manual" Tag="Manual"
                                Click="SourceFilter_Click"
                                Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                BorderThickness="0" CornerRadius="6" Padding="8,5" FontSize="11"/>
                        <Border Width="1" Height="16" Background="{ThemeResource BorderBrush}"
                                VerticalAlignment="Center" Margin="4,0"/>
                        <Button x:Name="ImportCsvBtn" Click="ImportCsv_Click"
                                Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource TextSecondaryBrush}"
                                BorderThickness="0"
                                CornerRadius="8" Padding="10,7"
                                ToolTipService.ToolTip="Import test cases from CSV or Excel file (.csv / .xlsx)">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8B7;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Import CSV" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="NewPlanBtn" Click="NewPlan_Click"
                                Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource TextSecondaryBrush}"
                                BorderThickness="0"
                                CornerRadius="8" Padding="10,7"
                                ToolTipService.ToolTip="Create a new empty test plan manually">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE710;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="New Plan" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <Button Click="UploadDesignDoc_Click"
                                Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource TextSecondaryBrush}"
                                BorderThickness="0"
                                CornerRadius="8" Padding="10,7"
                                ToolTipService.ToolTip="Upload a design document for extra context (optional)">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE8E5;" FontSize="13" FontFamily="Segoe Fluent Icons"/>
                                <TextBlock Text="Design Doc" FontSize="11"/>
                            </StackPanel>
                        </Button>
                        <TextBlock x:Name="DesignDocStatus"
                                   Foreground="#34D399" FontSize="11"
                                   VerticalAlignment="Center" Visibility="Collapsed"/>
                        <Button x:Name="ClearDesignDocBtn" Click="ClearDesignDoc_Click"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#F87171" Padding="4,4"
                                CornerRadius="4" Visibility="Collapsed"
                                ToolTipService.ToolTip="Remove design document">
                            <FontIcon Glyph="&#xE711;" FontSize="10" FontFamily="Segoe Fluent Icons"/>
                        </Button>
                        <Button x:Name="ClearAllBtn" Content="Clear All"
                                Click="ClearAllTestCases_Click"
                                Background="#3F1A1A" Foreground="#F87171"
                                CornerRadius="8" Padding="10,7"
                                Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Test plans / test cases list -->
                <ScrollViewer Grid.Row="2" Padding="16">
                    <StackPanel x:Name="TestCasesContainer" Spacing="16">

                        <!-- Empty state -->
                        <StackPanel x:Name="TestCaseEmptyState"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="12" Margin="0,80,0,0">
                            <FontIcon Glyph="&#xE9D5;" FontSize="40"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource TextSecondaryBrush}"
                                      HorizontalAlignment="Center"/>
                            <TextBlock Text="No test plans yet"
                                       Foreground="{ThemeResource TextSecondaryBrush}" FontSize="14"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Select a source and click Generate to create test cases organized into a test plan"
                                       Foreground="#4B5563" FontSize="12"
                                       HorizontalAlignment="Center" TextWrapping="Wrap"
                                       MaxWidth="400" TextAlignment="Center"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- Busy overlay -->
                <Grid x:Name="TestCaseBusyOverlay" Grid.Row="0" Grid.RowSpan="3"
                      Visibility="Collapsed"
                      Background="#CC0F0F13">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                        <ProgressRing IsActive="True" Width="48" Height="48"
                                      Foreground="#A78BFA"/>
                        <TextBlock Text="Generating test cases via Gemini..."
                                   Foreground="#E2E8F0" FontSize="14"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="This may take a moment"
                                   Foreground="#6B7280" FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- Test Runs panel                                    -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Grid x:Name="TestRunsPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{ThemeResource SurfaceBrush}"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="16,10">
                    <Grid>
                        <TextBlock Text="EXECUTION HISTORY" Foreground="{ThemeResource TextSecondaryBrush}"
                                   FontSize="10" FontWeight="SemiBold"
                                   CharacterSpacing="150" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                            <ToggleButton x:Name="ShowArchivedRunsToggle" Content="Show Archived"
                                          Click="ShowArchivedRunsToggle_Click"
                                          Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                          BorderBrush="{ThemeResource BorderBrush}" CornerRadius="6"
                                          Padding="10,7" FontSize="11"/>
                            <TextBlock x:Name="ExecutionCountText"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" Padding="16">
                    <StackPanel x:Name="ExecutionsContainer" Spacing="8">
                        <StackPanel x:Name="ExecutionEmptyState"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="12" Margin="0,80,0,0">
                            <FontIcon Glyph="&#xE768;" FontSize="40"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource TextSecondaryBrush}"
                                      HorizontalAlignment="Center"/>
                            <TextBlock Text="No test executions yet"
                                       Foreground="{ThemeResource TextSecondaryBrush}" FontSize="14"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Execute test cases from the Test Case Generation tab to see history here"
                                       Foreground="#4B5563" FontSize="12"
                                       HorizontalAlignment="Center" TextWrapping="Wrap"
                                       MaxWidth="400" TextAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- Reports panel                                      -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Grid x:Name="ReportsPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar row 1: report type + export -->
                <Border Grid.Row="0" Background="{ThemeResource SurfaceBrush}"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="16,10">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <TextBlock Text="REPORT" Foreground="{ThemeResource TextSecondaryBrush}"
                                       FontSize="10" FontWeight="SemiBold"
                                       CharacterSpacing="150" VerticalAlignment="Center"/>
                            <ComboBox x:Name="ReportTypePicker"
                                      SelectedIndex="0"
                                      Background="#252535" Foreground="#E2E8F0"
                                      BorderBrush="#2A2A3A" CornerRadius="8"
                                      MinWidth="180"
                                      SelectionChanged="ReportTypePicker_Changed">
                                <ComboBoxItem Content="Test Summary" Tag="Summary"/>
                                <ComboBoxItem Content="Test Cases (CSV)" Tag="TestCasesCsv"/>
                                <ComboBoxItem Content="Execution History (CSV)" Tag="ExecutionsCsv"/>
                            </ComboBox>
                            <Button x:Name="ExportReportBtn" Content="Export"
                                    Click="ExportReport_Click"
                                    Background="{ThemeResource AccentBrush}" Foreground="White"
                                    CornerRadius="8" Padding="10,7"/>
                            <TextBlock x:Name="ReportStatusText"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Toolbar row 2: plan / scope filter -->
                <Border Grid.Row="1" Background="{ThemeResource SurfaceBrush}"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="16,8">
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="SCOPE" Foreground="{ThemeResource TextSecondaryBrush}"
                                   FontSize="10" FontWeight="SemiBold"
                                   CharacterSpacing="150" VerticalAlignment="Center"/>
                        <Button x:Name="PlanFilterBtn"
                                Content="All Plans"
                                Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource TextPrimaryBrush}"
                                CornerRadius="8"
                                Padding="10,7" MinWidth="160"
                                HorizontalContentAlignment="Left">
                            <Button.Flyout>
                                <Flyout x:Name="PlanFilterFlyout" Placement="Bottom">
                                    <StackPanel x:Name="PlanFilterContainer" Spacing="4" MinWidth="260"/>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        <Button x:Name="SelectAllPlansBtn" Content="Select All"
                                Click="SelectAllPlans_Click"
                                Background="Transparent" Foreground="{ThemeResource AccentBrush}"
                                BorderThickness="0" Padding="10,7" FontSize="11"/>
                        <Button x:Name="ClearPlanSelectionBtn" Content="Clear Selection"
                                Click="ClearPlanSelection_Click"
                                Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                BorderThickness="0" Padding="10,7" FontSize="11"/>
                    </StackPanel>
                </Border>

                <!-- Report preview / content area -->
                <ScrollViewer Grid.Row="2" Padding="16">
                    <StackPanel x:Name="ReportsContainer" Spacing="16">

                        <!-- Empty state (shown when no data) -->
                        <StackPanel x:Name="ReportsEmptyState"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="12" Margin="0,80,0,0"
                                    Visibility="Collapsed">
                            <FontIcon Glyph="&#xE9F9;" FontSize="40"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource TextSecondaryBrush}"
                                      HorizontalAlignment="Center"/>
                            <TextBlock Text="No test data available"
                                       Foreground="{ThemeResource TextSecondaryBrush}" FontSize="14"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Generate test cases and run executions to see reports here"
                                       Foreground="#4B5563" FontSize="12"
                                       HorizontalAlignment="Center" TextWrapping="Wrap"
                                       MaxWidth="400" TextAlignment="Center"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>


        </Grid>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- Coverage Matrix panel                              -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Grid x:Name="CoverageMatrixPanel" Grid.Row="1" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Border Grid.Row="0" Background="{ThemeResource SurfaceBrush}"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="16,10">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <TextBlock Text="VIEW" Foreground="{ThemeResource TextSecondaryBrush}"
                                       FontSize="10" FontWeight="SemiBold"
                                       CharacterSpacing="150" VerticalAlignment="Center"/>
                            <Button x:Name="CoverageByIssueBtn" Content="By Issue"
                                    Click="CoverageViewMode_Click" Tag="Issue"
                                    Background="{ThemeResource ListAccentLowBrush}"
                                    Foreground="{ThemeResource AccentBrush}"
                                    CornerRadius="6" Padding="10,7" FontSize="11"/>
                            <Button x:Name="CoverageByModuleBtn" Content="By SAP Module"
                                    Click="CoverageViewMode_Click" Tag="SapModule"
                                    Background="Transparent"
                                    Foreground="{ThemeResource TextSecondaryBrush}"
                                    CornerRadius="6" Padding="10,7" FontSize="11"/>
                            <TextBlock x:Name="CoverageStatusText"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Matrix content -->
                <ScrollViewer Grid.Row="1" Padding="16">
                    <StackPanel x:Name="CoverageMatrixContainer" Spacing="12">

                        <!-- Empty state -->
                        <StackPanel x:Name="CoverageEmptyState"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="12" Margin="0,80,0,0">
                            <FontIcon Glyph="&#xE9D5;" FontSize="40"
                                      FontFamily="Segoe Fluent Icons"
                                      Foreground="{ThemeResource TextSecondaryBrush}"
                                      HorizontalAlignment="Center"/>
                            <TextBlock Text="No coverage data yet"
                                       Foreground="{ThemeResource TextSecondaryBrush}" FontSize="14"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Generate test cases from Jira or Linear issues to see coverage mapped here"
                                       Foreground="#4B5563" FontSize="12"
                                       HorizontalAlignment="Center" TextWrapping="Wrap"
                                       MaxWidth="400" TextAlignment="Center"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- Regression Builder panel                           -->
            <!-- ═══════════════════════════════════════════════════ -->
            <Grid x:Name="RegressionBuilderPanel" Grid.Row="1" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Border Grid.Row="0" Background="{ThemeResource SurfaceBrush}"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="16,10">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <TextBlock Text="FROM" Foreground="{ThemeResource TextSecondaryBrush}"
                                       FontSize="10" FontWeight="SemiBold"
                                       CharacterSpacing="150" VerticalAlignment="Center"/>
                            <DatePicker x:Name="RegressionFromDate"
                                        Background="#252535" Foreground="#E2E8F0" BorderBrush="#2A2A3A"
                                        CornerRadius="8"
                                        SelectedDateChanged="RegressionDate_Changed"/>
                            <TextBlock Text="TO" Foreground="{ThemeResource TextSecondaryBrush}"
                                       FontSize="10" FontWeight="SemiBold"
                                       CharacterSpacing="150" VerticalAlignment="Center"/>
                            <DatePicker x:Name="RegressionToDate"
                                        Background="#252535" Foreground="#E2E8F0" BorderBrush="#2A2A3A"
                                        CornerRadius="8"
                                        SelectedDateChanged="RegressionDate_Changed"/>
                            <Button Content="Clear Dates" Click="RegressionClearDates_Click"
                                    Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                    BorderThickness="0" CornerRadius="6" Padding="10,7" FontSize="11"/>
                            <TextBlock x:Name="RegressionStatusText"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button x:Name="BuildRegressionSuiteBtn"
                                Content="Build Regression Suite"
                                Click="BuildRegressionSuite_Click"
                                Background="{ThemeResource AccentBrush}" Foreground="White"
                                CornerRadius="8" Padding="10,7"
                                HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Content -->
                <ScrollViewer Grid.Row="1" Padding="16">
                    <StackPanel x:Name="RegressionBuilderContainer" Spacing="16">
                        <!-- Populated in code-behind -->
                    </StackPanel>
                </ScrollViewer>

                <!-- Busy overlay -->
                <Grid x:Name="RegressionBusyOverlay" Grid.Row="0" Grid.RowSpan="2"
                      Visibility="Collapsed"
                      Background="#CC0F0F13">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                        <ProgressRing IsActive="True" Width="48" Height="48"
                                      Foreground="#A78BFA"/>
                        <TextBlock Text="Generating smoke test subset via Gemini..."
                                   Foreground="#E2E8F0" FontSize="14"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="This may take a moment"
                                   Foreground="#6B7280" FontSize="12"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>

    </Grid>
</Page>
