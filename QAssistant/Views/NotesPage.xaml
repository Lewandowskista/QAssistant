<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QAssistant.Views.NotesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationBackgroundBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Notes Sidebar -->
        <Border Grid.Column="0" Background="{ThemeResource SurfaceVariantBrush}"
                BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="NOTES"
                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="9" FontWeight="SemiBold"
                           Margin="16,16,16,8" CharacterSpacing="180"/>

                <ListView Grid.Row="1" x:Name="NotesList"
                          Background="Transparent" SelectionMode="Single"
                          SelectionChanged="NotesList_SelectionChanged"
                          CanReorderItems="True" CanDragItems="True"
                          AllowDrop="True"
                          DragItemsCompleted="NotesList_DragItemsCompleted"
                          KeyDown="NotesList_KeyDown">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="Margin" Value="6,2"/>
                            <Setter Property="CornerRadius" Value="8"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <ListViewItemPresenter
                                            SelectedBackground="{ThemeResource ListAccentLowBrush}"
                                            SelectedForeground="{ThemeResource TextPrimaryBrush}"
                                            SelectedPressedBackground="{ThemeResource ListAccentMediumBrush}"
                                            SelectedPointerOverBackground="{ThemeResource ListAccentMediumBrush}"
                                            PointerOverBackground="{ThemeResource HoverBrush}"
                                            PressedBackground="{ThemeResource BorderBrush}"
                                            CornerRadius="8"
                                            ContentMargin="12,8"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="2" Padding="4">
                                <TextBlock Text="{Binding Title}"
                                           Foreground="{ThemeResource TextPrimaryBrush}" FontSize="13"/>
                                <TextBlock Text="{Binding UpdatedAt}"
                                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Button Grid.Row="2" Content="+ New Note"
                        Click="AddNote_Click"
                        HorizontalAlignment="Stretch"
                        Margin="12,8,12,16"
                        Background="{ThemeResource HoverBrush}"
                        Foreground="{ThemeResource AccentBrush}"
                        CornerRadius="8"
                        Padding="12,8"/>
            </Grid>
        </Border>

        <!-- Editor -->
        <Grid Grid.Column="1">
            <StackPanel x:Name="EmptyState"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12">
                <TextBlock Text="Select a note or create a new one"
                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="14"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <Grid x:Name="EditorPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <TextBox Grid.Row="0"
                         x:Name="NoteTitleBox"
                         PlaceholderText="Note title..."
                         FontSize="20" FontWeight="SemiBold"
                         Background="Transparent"
                         BorderThickness="0,0,0,1"
                         BorderBrush="{ThemeResource BorderBrush}"
                         Foreground="{ThemeResource TextPrimaryBrush}"
                         Padding="20,16"
                         TextChanged="NoteTitle_Changed"/>

                <!-- Content + inline attachments -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBox x:Name="NoteContentBox"
                                 PlaceholderText="Write your note here..."
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{ThemeResource TextPrimaryBrush}"
                                 Padding="20,16"
                                 FontSize="14"
                                 MinHeight="200"
                                 TextChanged="NoteContent_Changed"/>

                        <StackPanel x:Name="AttachmentItems" Spacing="8"
                                    Margin="20,0,20,16"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer -->
                <Border Grid.Row="2" Background="{ThemeResource SurfaceBrush}"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,1,0,0"
                        Padding="20,10">
                    <Grid>
                        <TextBlock x:Name="LastSavedText"
                                   Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"
                                   VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right" Spacing="6">
                            <Button Content="Paste"
                                    Click="PasteMedia_Click"
                                    Background="{ThemeResource HoverBrush}"
                                    Foreground="{ThemeResource AccentBrush}"
                                    CornerRadius="6"
                                    Padding="10,6"/>
                            <Button Content="+ Attach"
                                    Click="AttachFile_Click"
                                    Background="{ThemeResource HoverBrush}"
                                    Foreground="{ThemeResource AccentBrush}"
                                    CornerRadius="6"
                                    Padding="10,6"/>
                            <Button Content="Delete Note"
                                    Click="DeleteNote_Click"
                                    Background="#3F1A1A"
                                    Foreground="#F87171"
                                    CornerRadius="6"
                                    Padding="12,6"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>