<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QAssistant.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationBackgroundBrush}">
    <ScrollViewer Padding="24">
        <StackPanel Spacing="32" MaxWidth="600">

            <!-- Project Context -->
            <StackPanel Spacing="4">
                <TextBlock x:Name="ProjectContextText"
                           Foreground="{ThemeResource AccentBrush}" FontSize="12"
                           FontWeight="SemiBold"/>
            </StackPanel>

            <!-- General Settings -->
            <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="12"
        Padding="20" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1"
        Margin="0,0,0,16">
                <StackPanel Spacing="16">
                    <TextBlock Text="GENERAL" Foreground="{ThemeResource TextSecondaryBrush}"
                    FontSize="10" FontWeight="SemiBold"
                    CharacterSpacing="150"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,16,0">
                            <TextBlock Text="Minimize to System Tray"
                           Foreground="{ThemeResource TextPrimaryBrush}" FontSize="14"/>
                            <TextBlock Text="When enabled, closing the window sends it to the system tray instead of exiting"
                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"
                           TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="MinimizeToTrayToggle"
                          Grid.Column="1"
                          VerticalAlignment="Center"
                          Toggled="MinimizeToTrayToggle_Toggled"
                          OnContent="" OffContent=""/>
                    </Grid>

                    <!-- Refresh Projects Sidebar -->
                    <Button x:Name="RefreshProjectsButton" Content="Refresh Projects Sidebar"
                    Click="RefreshProjects_Click"
                    Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource AccentBrush}"
                    CornerRadius="8" Padding="10,7"
                    HorizontalAlignment="Left"/>
                    <TextBlock Text="If projects don't appear, click this button to manually refresh the sidebar."
                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>

                    <!-- SAP Commerce Context toggle -->
                    <Border Height="1" Background="{ThemeResource BorderBrush}" Margin="0,4,0,4"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,16,0">
                            <TextBlock Text="SAP Commerce Context"
                           Foreground="{ThemeResource TextPrimaryBrush}" FontSize="14"/>
                            <TextBlock Text="When enabled, SAP Commerce Cloud (Hybris) domain knowledge is included in AI prompts for platform-aware test case generation and analysis"
                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"
                           TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="SapCommerceContextToggle"
                          Grid.Column="1"
                          VerticalAlignment="Center"
                          Toggled="SapCommerceContextToggle_Toggled"
                          OnContent="" OffContent=""/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Automation API Section -->
            <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="12"
                    BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" Padding="24">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Automation API" Foreground="{ThemeResource TextPrimaryBrush}"
                                   FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="Expose a local REST API so automation suites (Playwright, Cypress, etc.) can query test cases and submit execution results."/>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,16,0">
                            <TextBlock Text="Enable Automation API"
                                       Foreground="{ThemeResource TextPrimaryBrush}" FontSize="14"/>
                            <TextBlock Text="Starts a local HTTP server your test runners can call"
                                       Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="AutomationApiToggle"
                                      Grid.Column="1"
                                      VerticalAlignment="Center"
                                      Toggled="AutomationApiToggle_Toggled"
                                      OnContent="" OffContent=""/>
                    </Grid>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Port" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBox x:Name="AutomationApiPortBox"
                                 PlaceholderText="5248"
                                 Background="{ThemeResource ApplicationBackgroundBrush}"
                                 Foreground="{ThemeResource TextPrimaryBrush}"
                                 BorderBrush="{ThemeResource BorderBrush}"
                                 CornerRadius="8"
                                 Padding="12,10"
                                 MaxWidth="120"
                                 HorizontalAlignment="Left"/>
                        <TextBlock Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"
                                   Text="Default: 5248 · Changes take effect on next toggle or restart"/>
                    </StackPanel>

                    <Button Content="Save Port" Click="SaveAutomationPort_Click"
                            Background="{ThemeResource HoverBrush}"
                            Foreground="{ThemeResource AccentBrush}"
                            CornerRadius="8"
                            Padding="10,7"/>

                    <StackPanel Spacing="8">
                        <TextBlock Text="API Key" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                        <PasswordBox x:Name="AutomationApiKeyBox"
                                     IsEnabled="False"
                                     Background="{ThemeResource ApplicationBackgroundBrush}"
                                     Foreground="{ThemeResource TextPrimaryBrush}"
                                     BorderBrush="{ThemeResource BorderBrush}"
                                     CornerRadius="8"
                                     Padding="12,10"/>
                        <TextBlock Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"
                                   Text="All requests must include: Authorization: Bearer &lt;key&gt;"/>
                        <Button Content="Regenerate Key" Click="RegenerateApiKey_Click"
                                Background="#3F1A1A" Foreground="#F87171"
                                CornerRadius="8" Padding="10,7"/>
                    </StackPanel>

                    <Border x:Name="AutomationApiStatusBorder" Visibility="Collapsed"
                            CornerRadius="8" Padding="12,8">
                        <TextBlock x:Name="AutomationApiStatusText" FontSize="12"/>
                    </Border>

                    <Border Background="{ThemeResource ApplicationBackgroundBrush}"
                            CornerRadius="8" Padding="16,12"
                            BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="6">
                            <TextBlock Text="ENDPOINTS" Foreground="{ThemeResource TextSecondaryBrush}"
                                       FontSize="10" FontWeight="SemiBold" CharacterSpacing="150"/>
                            <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{ThemeResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       Text="GET  /api/projects&#x0a;GET  /api/projects/{id}/testplans&#x0a;GET  /api/projects/{id}/testcases&#x0a;GET  /api/projects/{id}/testcases?planId={guid}&#x0a;GET  /api/projects/{id}/testcases/{tcId}&#x0a;GET  /api/projects/{id}/executions&#x0a;POST /api/projects/{id}/executions&#x0a;POST /api/projects/{id}/executions/batch"/>
                            <TextBlock FontSize="11" Foreground="{ThemeResource TextSecondaryBrush}"
                                       TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="Header: Authorization: Bearer &lt;api-key&gt;&#x0a;POST body: { &quot;testCaseDisplayId&quot;: &quot;TC-001&quot;, &quot;result&quot;: &quot;passed&quot;, &quot;actualResult&quot;: &quot;...&quot;, &quot;notes&quot;: &quot;...&quot; }"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Linear Section -->
            <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="12"
                    BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" Padding="24">
                <StackPanel Spacing="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Linear" Foreground="{ThemeResource TextPrimaryBrush}"
                                       FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"
                                       TextWrapping="Wrap"
                                       Text="Get your API key from linear.app → Settings → API → Personal API Keys"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Get API Key"
                                Click="OpenLinearKeys_Click"
                                Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource AccentBrush}"
                                CornerRadius="8" Padding="10,7"
                                VerticalAlignment="Top"/>
                    </Grid>

                    <StackPanel Spacing="8">
                        <TextBlock Text="API Key" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                        <PasswordBox x:Name="LinearApiKeyBox"
                                     PlaceholderText="lin_api_..."
                                     Background="{ThemeResource ApplicationBackgroundBrush}"
                                     Foreground="{ThemeResource TextPrimaryBrush}"
                                     BorderBrush="{ThemeResource BorderBrush}"
                                     CornerRadius="8"
                                     Padding="12,10"
                                     Visibility="Collapsed"/>
                    </StackPanel>

                    <TextBlock Text="CONNECTIONS" Foreground="{ThemeResource TextSecondaryBrush}"
                               FontSize="10" FontWeight="SemiBold" CharacterSpacing="150"/>

                    <StackPanel x:Name="LinearConnectionsList" Spacing="8"/>

                    <Button x:Name="AddLinearBtn" Content="＋ Add Connection"
                            Click="AddLinear_Click"
                            Background="{ThemeResource HoverBrush}"
                            Foreground="{ThemeResource AccentBrush}"
                            CornerRadius="8" Padding="10,7"
                            HorizontalAlignment="Left"/>

                    <Border x:Name="LinearConnectionFormPanel" Visibility="Collapsed"
                            Background="{ThemeResource ApplicationBackgroundBrush}"
                            CornerRadius="8" Padding="16,14"
                            BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock x:Name="LinearFormTitle" Text="New Connection"
                                       Foreground="{ThemeResource TextPrimaryBrush}"
                                       FontSize="14" FontWeight="SemiBold"/>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Label" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBox x:Name="LinearConnLabelBox"
                                         PlaceholderText="e.g. Frontend, Backend"
                                         Background="{ThemeResource SurfaceVariantBrush}"
                                         Foreground="{ThemeResource TextPrimaryBrush}"
                                         BorderBrush="{ThemeResource BorderBrush}"
                                         CornerRadius="8" Padding="12,10"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="API Key" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                                <PasswordBox x:Name="LinearConnApiKeyBox"
                                             PlaceholderText="lin_api_... (leave blank to keep existing)"
                                             Background="{ThemeResource SurfaceVariantBrush}"
                                             Foreground="{ThemeResource TextPrimaryBrush}"
                                             BorderBrush="{ThemeResource BorderBrush}"
                                             CornerRadius="8" Padding="12,10"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Team ID" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBox x:Name="LinearConnTeamIdBox"
                                         PlaceholderText="Your Linear Team ID"
                                         Background="{ThemeResource SurfaceVariantBrush}"
                                         Foreground="{ThemeResource TextPrimaryBrush}"
                                         BorderBrush="{ThemeResource BorderBrush}"
                                         CornerRadius="8" Padding="12,10"/>
                                <TextBlock Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"
                                           Text="Go to linear.app → Settings → Team → copy the ID from the URL"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button Content="Save Connection"
                                        Click="SaveLinear_Click"
                                        Background="{ThemeResource HoverBrush}"
                                        Foreground="{ThemeResource AccentBrush}"
                                        CornerRadius="8" Padding="10,7"/>
                                <Button Content="Test"
                                        Click="TestLinear_Click"
                                        Background="{ThemeResource HoverBrush}"
                                        Foreground="{ThemeResource TextSecondaryBrush}"
                                        CornerRadius="8" Padding="10,7"/>
                                <Button Content="Cancel"
                                        Click="CancelLinearForm_Click"
                                        Background="#3F1A1A" Foreground="#F87171"
                                        CornerRadius="8" Padding="10,7"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border x:Name="LinearStatusBorder" Visibility="Collapsed"
                            CornerRadius="8" Padding="12,8">
                        <TextBlock x:Name="LinearStatusText" FontSize="12"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Jira Section -->
            <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="12"
                    BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" Padding="24">
                <StackPanel Spacing="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Jira" Foreground="{ThemeResource TextPrimaryBrush}"
                                       FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"
                                       TextWrapping="Wrap"
                                       Text="Get your API token from id.atlassian.com → Security → API tokens"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Get API Token"
                                Click="OpenJiraKeys_Click"
                                Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource AccentBrush}"
                                CornerRadius="8" Padding="10,7"
                                VerticalAlignment="Top"/>
                    </Grid>

                    <TextBlock Text="CONNECTIONS" Foreground="{ThemeResource TextSecondaryBrush}"
                               FontSize="10" FontWeight="SemiBold" CharacterSpacing="150"/>

                    <StackPanel x:Name="JiraConnectionsList" Spacing="8"/>

                    <Button x:Name="AddJiraBtn" Content="＋ Add Connection"
                            Click="AddJira_Click"
                            Background="{ThemeResource HoverBrush}"
                            Foreground="{ThemeResource AccentBrush}"
                            CornerRadius="8" Padding="10,7"
                            HorizontalAlignment="Left"/>

                    <Border x:Name="JiraConnectionFormPanel" Visibility="Collapsed"
                            Background="{ThemeResource ApplicationBackgroundBrush}"
                            CornerRadius="8" Padding="16,14"
                            BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock x:Name="JiraFormTitle" Text="New Connection"
                                       Foreground="{ThemeResource TextPrimaryBrush}"
                                       FontSize="14" FontWeight="SemiBold"/>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Label" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBox x:Name="JiraConnLabelBox"
                                         PlaceholderText="e.g. Frontend, Backend OMS"
                                         Background="{ThemeResource SurfaceVariantBrush}"
                                         Foreground="{ThemeResource TextPrimaryBrush}"
                                         BorderBrush="{ThemeResource BorderBrush}"
                                         CornerRadius="8" Padding="12,10"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Domain" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBox x:Name="JiraConnDomainBox"
                                         PlaceholderText="your-company (from your-company.atlassian.net)"
                                         Background="{ThemeResource SurfaceVariantBrush}"
                                         Foreground="{ThemeResource TextPrimaryBrush}"
                                         BorderBrush="{ThemeResource BorderBrush}"
                                         CornerRadius="8" Padding="12,10"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Email" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBox x:Name="JiraConnEmailBox"
                                         PlaceholderText="your@email.com"
                                         Background="{ThemeResource SurfaceVariantBrush}"
                                         Foreground="{ThemeResource TextPrimaryBrush}"
                                         BorderBrush="{ThemeResource BorderBrush}"
                                         CornerRadius="8" Padding="12,10"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="API Token" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                                <PasswordBox x:Name="JiraConnApiTokenBox"
                                             PlaceholderText="Your Jira API token (leave blank to keep existing)"
                                             Background="{ThemeResource SurfaceVariantBrush}"
                                             Foreground="{ThemeResource TextPrimaryBrush}"
                                             BorderBrush="{ThemeResource BorderBrush}"
                                             CornerRadius="8" Padding="12,10"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Project Key" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBox x:Name="JiraConnProjectKeyBox"
                                         PlaceholderText="e.g. QA, DEV, PROJ"
                                         Background="{ThemeResource SurfaceVariantBrush}"
                                         Foreground="{ThemeResource TextPrimaryBrush}"
                                         BorderBrush="{ThemeResource BorderBrush}"
                                         CornerRadius="8" Padding="12,10"/>
                                <TextBlock Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"
                                           Text="The short key shown before issue numbers e.g. QA-123"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button Content="Save Connection"
                                        Click="SaveJira_Click"
                                        Background="{ThemeResource HoverBrush}"
                                        Foreground="{ThemeResource AccentBrush}"
                                        CornerRadius="8" Padding="10,7"/>
                                <Button Content="Test"
                                        Click="TestJira_Click"
                                        Background="{ThemeResource HoverBrush}"
                                        Foreground="{ThemeResource TextSecondaryBrush}"
                                        CornerRadius="8" Padding="10,7"/>
                                <Button Content="Cancel"
                                        Click="CancelJiraForm_Click"
                                        Background="#3F1A1A" Foreground="#F87171"
                                        CornerRadius="8" Padding="10,7"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border x:Name="JiraStatusBorder" Visibility="Collapsed"
                            CornerRadius="8" Padding="12,8">
                        <TextBlock x:Name="JiraStatusText" FontSize="12"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Google AI Studio Section -->
            <Border Background="#1A1A24" CornerRadius="12"
                    BorderBrush="#2A2A3A" BorderThickness="1" Padding="24">
                <StackPanel Spacing="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Google AI Studio" Foreground="#E2E8F0"
                                       FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Foreground="#6B7280" FontSize="12"
                                       TextWrapping="Wrap"
                                       Text="Get your API key from aistudio.google.com → API Keys"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Get API Key"
                                Click="OpenGeminiKeys_Click"
                                Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource AccentBrush}"
                                CornerRadius="8" Padding="10,7"
                                VerticalAlignment="Top"/>
                    </Grid>

                    <StackPanel Spacing="8">
                        <TextBlock Text="API Key" Foreground="#9CA3AF" FontSize="12"/>
                        <PasswordBox x:Name="GeminiApiKeyBox"
                                     PlaceholderText="Enter your Google AI Studio API key..."
                                     Background="#0F0F13"
                                     Foreground="#E2E8F0"
                                     BorderBrush="#2A2A3A"
                                     CornerRadius="8"
                                     Padding="12,10"/>
                    </StackPanel>

                    <Button Content="Save API Key" Click="SaveGeminiKey_Click"
                            Background="{ThemeResource HoverBrush}"
                            Foreground="{ThemeResource AccentBrush}"
                            CornerRadius="8"
                            Padding="10,7"/>

                    <Border x:Name="GeminiStatusBorder" Visibility="Collapsed"
                            CornerRadius="8" Padding="12,8">
                        <TextBlock x:Name="GeminiStatusText" FontSize="12"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- SAP CCv2 Section -->
            <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="12"
                    BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" Padding="24">
                <StackPanel Spacing="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="SAP Commerce Cloud v2 (CCv2)"
                                       Foreground="{ThemeResource TextPrimaryBrush}"
                                       FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"
                                       TextWrapping="Wrap"
                                       Text="Enter your subscription code and a Management API token to enable the CCv2 Deployments panel on the SAP page."/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="API Docs"
                                Click="OpenCcv2Docs_Click"
                                Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource AccentBrush}"
                                CornerRadius="8" Padding="10,7"
                                VerticalAlignment="Top"/>
                    </Grid>

                    <StackPanel Spacing="8">
                        <TextBlock Text="Subscription Code" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBox x:Name="Ccv2SubscriptionCodeBox"
                                 PlaceholderText="Your CCv2 subscription code"
                                 Background="{ThemeResource ApplicationBackgroundBrush}"
                                 Foreground="{ThemeResource TextPrimaryBrush}"
                                 BorderBrush="{ThemeResource BorderBrush}"
                                 CornerRadius="8"
                                 Padding="12,10"/>
                        <TextBlock Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"
                                   Text="Found in the SAP Commerce Cloud Portal under your project settings"/>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="API Token" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                        <PasswordBox x:Name="Ccv2ApiTokenBox"
                                     PlaceholderText="Bearer token from the CCv2 portal"
                                     Background="{ThemeResource ApplicationBackgroundBrush}"
                                     Foreground="{ThemeResource TextPrimaryBrush}"
                                     BorderBrush="{ThemeResource BorderBrush}"
                                     CornerRadius="8"
                                     Padding="12,10"/>
                        <TextBlock Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"
                                   Text="Generate in Cloud Portal → API Token Management"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Content="Save CCv2 Credentials"
                                Click="SaveCcv2_Click"
                                Background="{ThemeResource HoverBrush}"
                                Foreground="{ThemeResource AccentBrush}"
                                CornerRadius="8"
                                Padding="10,7"/>
                        <Button Content="Test Connection"
                                Click="TestCcv2_Click"
                                Background="{ThemeResource HoverBrush}"
                                Foreground="{ThemeResource TextSecondaryBrush}"
                                CornerRadius="8"
                                Padding="10,7"/>
                        <Button Content="Disconnect"
                                Click="DisconnectCcv2_Click"
                                Background="#3F1A1A"
                                Foreground="#F87171"
                                CornerRadius="8"
                                Padding="10,7"/>
                    </StackPanel>

                    <Border x:Name="Ccv2StatusBorder" Visibility="Collapsed"
                            CornerRadius="8" Padding="12,8">
                        <TextBlock x:Name="Ccv2StatusText" FontSize="12"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Diagnostics Section -->
            <Border Background="#1A1A24" CornerRadius="12"
                    BorderBrush="#2A2A3A" BorderThickness="1" Padding="24">
                <StackPanel Spacing="12">
                    <TextBlock Text="DIAGNOSTICS" Foreground="#6B7280"
                               FontSize="10" FontWeight="SemiBold" CharacterSpacing="150"/>
                    <TextBlock Foreground="#9CA3AF" FontSize="12"
                               TextWrapping="Wrap"
                               Text="View storage paths and logs to help debug data persistence issues."/>
                    <Button Content="View Storage Diagnostics" Click="ViewStorageDiagnostics_Click"
                            Background="{ThemeResource HoverBrush}"
                            Foreground="{ThemeResource AccentBrush}"
                            CornerRadius="8"
                            Padding="10,7"/>
                </StackPanel>
            </Border>

            <!-- Project Sharing Section -->
            <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="12"
                    BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1" Padding="24">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="PROJECT SHARING" Foreground="{ThemeResource TextSecondaryBrush}"
                                   FontSize="10" FontWeight="SemiBold" CharacterSpacing="150"/>
                        <TextBlock Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"
                                   TextWrapping="Wrap"
                                   Text="Export the current project to a JSON file to share with teammates, or import a project from a shared file. Credentials are never exported — they must be re-entered on the receiving machine."/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Export Project…" Click="ExportProject_Click"
                                Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource AccentBrush}"
                                CornerRadius="8" Padding="10,7"/>
                        <Button Content="Import Project…" Click="ImportProject_Click"
                                Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource AccentBrush}"
                                CornerRadius="8" Padding="10,7"/>
                    </StackPanel>
                    <Border x:Name="ShareStatusBorder" Visibility="Collapsed" CornerRadius="8" Padding="12,8">
                        <TextBlock x:Name="ShareStatusText" FontSize="12" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

                    <!-- Diagnostics Section -->
                    <Border Background="#1A1A24" CornerRadius="12"
                            BorderBrush="#2A2A3A" BorderThickness="1" Padding="24">
                        <StackPanel Spacing="16">
                            <TextBlock Text="DIAGNOSTICS" Foreground="#6B7280"
                           FontSize="10" FontWeight="SemiBold"
                           CharacterSpacing="150"/>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Data Storage Path" Foreground="#E2E8F0" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock x:Name="DataPathText" Text="" 
                                   Foreground="#A78BFA" FontSize="11" 
                                   TextWrapping="Wrap" FontFamily="Consolas"/>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Log File Path" Foreground="#E2E8F0" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock x:Name="LogPathText" Text="" 
                                   Foreground="#A78BFA" FontSize="11" 
                                   TextWrapping="Wrap" FontFamily="Consolas"/>
                            </StackPanel>

                    <Button x:Name="OpenLogButton" Content="Open Log File"
                    Click="OpenLogFile_Click"
                    Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource AccentBrush}"
                    CornerRadius="8" Padding="10,7"/>
                        </StackPanel>
                    </Border>

                    <!-- Footer watermark -->
                    <StackPanel HorizontalAlignment="Stretch" Margin="0,8,0,0">
                        <Border Background="Transparent" Padding="8,6" HorizontalAlignment="Stretch">
                            <TextBlock x:Name="CopyrightText"
                                       Text="© 2026 Lewandowskista · QAssistant"
                                       Foreground="{ThemeResource TextSecondaryBrush}"
                                       FontSize="11"
                                       HorizontalAlignment="Center"
                                       Opacity="0.75"
