<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="QAssistant.Views.CsvImportDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Import Test Cases"
    PrimaryButtonText="Import"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    MinWidth="560"
    MaxWidth="640">

    <ScrollViewer MaxHeight="580" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20" Padding="0,4,4,4">

            <!-- File info banner -->
            <Border Background="#1A1A2E" CornerRadius="8" Padding="14,10"
                    BorderBrush="#2A2A3A" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xE8A5;" FontSize="20" FontFamily="Segoe Fluent Icons"
                              Foreground="#A78BFA" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock x:Name="FileNameText" FontSize="13" Foreground="#E2E8F0"
                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="RowCountText" FontSize="11" Foreground="#9CA3AF"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Test plan name -->
            <StackPanel Spacing="6">
                <TextBlock Text="TEST PLAN NAME" FontSize="9" FontWeight="SemiBold"
                           Foreground="#A78BFA" CharacterSpacing="180"/>
                <TextBox x:Name="PlanNameBox"
                         Background="#252535" Foreground="#E2E8F0"
                         BorderBrush="#2A2A3A" CornerRadius="8" Padding="12,8"
                         PlaceholderText="e.g. TestRail Import · Jan 2026"/>
            </StackPanel>

            <!-- Column mapping -->
            <StackPanel Spacing="8">
                <TextBlock Text="MAP COLUMNS" FontSize="9" FontWeight="SemiBold"
                           Foreground="#A78BFA" CharacterSpacing="180"/>
                <TextBlock Text="Assign each CSV column to a test case field, or select (Ignore) to skip it."
                           FontSize="11" Foreground="#9CA3AF" TextWrapping="Wrap"/>

                <!-- Header row -->
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="CSV Column" FontSize="10" FontWeight="SemiBold"
                               Foreground="#6B7280" Margin="4,0"/>
                    <TextBlock Grid.Column="2" Text="Test Case Field" FontSize="10" FontWeight="SemiBold"
                               Foreground="#6B7280" Margin="4,0"/>
                </Grid>

                <StackPanel x:Name="MappingContainer" Spacing="6"/>
            </StackPanel>

            <!-- Preview -->
            <StackPanel Spacing="8">
                <TextBlock Text="PREVIEW (first 3 rows)" FontSize="9" FontWeight="SemiBold"
                           Foreground="#A78BFA" CharacterSpacing="180"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="PreviewContainer" Spacing="4"/>
                </ScrollViewer>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</ContentDialog>
