<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QAssistant.Views.FilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationBackgroundBrush}"
    AllowDrop="True"
    DragOver="Page_DragOver"
    DragLeave="Page_DragLeave"
    Drop="Page_Drop">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar -->
        <Border Grid.Row="0" Background="{ThemeResource SurfaceBrush}"
                BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="FILES" Foreground="{ThemeResource TextSecondaryBrush}"
                               FontSize="9" FontWeight="SemiBold"
                               CharacterSpacing="180" VerticalAlignment="Center"/>
                    <TextBlock x:Name="DropHintText"
                               Text="— Drop files here or paste a screenshot"
                               Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Right">
                    <Button Content="Paste Screenshot"
                            Click="PasteScreenshot_Click"
                            Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource AccentBrush}"
                            CornerRadius="8" Padding="12,6"/>
                    <Button Content="Browse Files"
                            Click="BrowseFiles_Click"
                            Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource AccentBrush}"
                            CornerRadius="8" Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Files Grid -->
        <ScrollViewer Grid.Row="1" Padding="16">
            <StackPanel Spacing="12">

                <!-- Empty state -->
                <StackPanel x:Name="EmptyState"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="12" Margin="0,80,0,0">
                    <TextBlock Text="No files yet"
                               Foreground="{ThemeResource TextSecondaryBrush}" FontSize="14"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Drop files, paste screenshots or click Browse"
                               Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Files list -->
                <ListView x:Name="FilesList"
                          CanReorderItems="True"
CanDragItems="True"
AllowDrop="True"
DragItemsCompleted="FilesList_DragItemsCompleted"
                          Background="Transparent"
                          SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,4"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>