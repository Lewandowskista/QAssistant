<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QAssistant.Views.LinksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationBackgroundBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Links Sidebar -->
        <Border Grid.Column="0" Background="{ThemeResource SurfaceVariantBrush}"
                BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="LINKS"
                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="9" FontWeight="SemiBold"
                           Margin="16,16,16,8" CharacterSpacing="180"/>

                <ListView Grid.Row="1" x:Name="LinksList"
          Background="Transparent" SelectionMode="Single"
          SelectionChanged="LinksList_SelectionChanged"
          RightTapped="LinksList_RightTapped"
          CanReorderItems="True" CanDragItems="True"
          AllowDrop="True"
          DragItemsCompleted="LinksList_DragItemsCompleted">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="Margin" Value="6,2"/>
                            <Setter Property="CornerRadius" Value="8"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <ListViewItemPresenter
                                            SelectedBackground="{ThemeResource ListAccentLowBrush}"
                                            SelectedForeground="{ThemeResource TextPrimaryBrush}"
                                            SelectedPressedBackground="{ThemeResource ListAccentMediumBrush}"
                                            SelectedPointerOverBackground="{ThemeResource ListAccentMediumBrush}"
                                            PointerOverBackground="{ThemeResource HoverBrush}"
                                            PressedBackground="{ThemeResource BorderBrush}"
                                            CornerRadius="8"
                                            ContentMargin="12,8"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="2" Padding="4">
                                <TextBlock Text="{Binding Title}"
                                           Foreground="{ThemeResource TextPrimaryBrush}" FontSize="13"/>
                                <TextBlock Text="{Binding Type}"
                                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Button Grid.Row="2" Content="+ Add Link"
                        Click="AddLink_Click"
                        HorizontalAlignment="Stretch"
                        Margin="12,8,12,16"
                        Background="{ThemeResource HoverBrush}"
                        Foreground="{ThemeResource AccentBrush}"
                        CornerRadius="8"
                        Padding="12,8"/>
            </Grid>
        </Border>

        <!-- WebView / Empty State -->
        <Grid Grid.Column="1">
            <StackPanel x:Name="EmptyState"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12">
                <TextBlock Text="Select a link to preview it"
                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="14"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <Border x:Name="WebViewContainer" Visibility="Collapsed">
                <controls:WebView2 x:Name="EmbedWebView"/>
            </Border>
        </Grid>
    </Grid>
</Page>