<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QAssistant.Views.LinksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    Background="{ThemeResource ApplicationBackgroundBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Links Sidebar -->
        <Border Grid.Column="0" Background="{ThemeResource SurfaceBrush}"
                BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="12,12,8,8"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1">
                    <TextBlock Text="LINKS" Foreground="{ThemeResource TextSecondaryBrush}"
                               FontSize="9" FontWeight="SemiBold" CharacterSpacing="180"
                               VerticalAlignment="Center"/>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="4" Padding="8,8">
                        <ListView x:Name="LinksList"
                                  Background="Transparent" SelectionMode="Single"
                                  SelectionChanged="LinksList_SelectionChanged"
                                  RightTapped="LinksList_RightTapped"
                                  CanReorderItems="True" CanDragItems="True"
                                  AllowDrop="True"
                                  DragItemsCompleted="LinksList_DragItemsCompleted">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,2"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <ListViewItemPresenter
                                                    SelectedBackground="{ThemeResource ListAccentLowBrush}"
                                                    SelectedForeground="{ThemeResource TextPrimaryBrush}"
                                                    SelectedPressedBackground="{ThemeResource ListAccentMediumBrush}"
                                                    SelectedPointerOverBackground="{ThemeResource ListAccentMediumBrush}"
                                                    PointerOverBackground="{ThemeResource HoverBrush}"
                                                    PressedBackground="{ThemeResource BorderBrush}"
                                                    CornerRadius="6"
                                                    ContentMargin="10,7"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{ThemeResource TextPrimaryBrush}" FontSize="12"/>
                                        <TextBlock Text="{Binding Type}"
                                                   Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </ScrollViewer>

                <Button Grid.Row="2" Content="+ Add Link"
                        Click="AddLink_Click"
                        HorizontalAlignment="Stretch"
                        Margin="8,4,8,12"
                        Background="{ThemeResource HoverBrush}"
                        Foreground="{ThemeResource AccentBrush}"
                        CornerRadius="8"
                        Padding="10,7"/>
            </Grid>
        </Border>

        <!-- WebView / Empty State -->
        <Grid Grid.Column="1">
            <StackPanel x:Name="EmptyState"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="12">
                <FontIcon Glyph="&#xE71B;" FontSize="40" FontFamily="Segoe Fluent Icons"
                          Foreground="{ThemeResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="Select a link to preview it"
                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="14"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <Border x:Name="WebViewContainer" Visibility="Collapsed">
                <controls:WebView2 x:Name="EmbedWebView"/>
            </Border>
        </Grid>
    </Grid>
</Page>