<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QAssistant.Views.ApiPlaygroundPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationBackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Saved requests sidebar -->
        <Border Grid.Column="0" Background="{ThemeResource SurfaceVariantBrush}"
                BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="4" Padding="16,16,16,8">
                    <TextBlock Text="API PLAYGROUND" Foreground="{ThemeResource TextSecondaryBrush}"
                               FontSize="9" FontWeight="SemiBold" CharacterSpacing="180"/>
                    <TextBlock Text="HTTP client for OCC, HAC, Jira, Linear"
                               Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11" TextWrapping="Wrap"/>
                </StackPanel>

                <ListView Grid.Row="1" x:Name="RequestList" Background="Transparent"
                          SelectionMode="Single" SelectionChanged="RequestList_SelectionChanged">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="Margin" Value="6,2"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <ListViewItemPresenter
                                            SelectedBackground="{ThemeResource ListAccentLowBrush}"
                                            PointerOverBackground="{ThemeResource HoverBrush}"
                                            CornerRadius="8" ContentMargin="10,8"/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border CornerRadius="3" Padding="4,1">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding MethodColor}"/>
                                        </Border.Background>
                                        <TextBlock Text="{Binding Method}" FontSize="9"
                                                   Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{ThemeResource TextPrimaryBrush}" FontSize="12"/>
                                </StackPanel>
                                <TextBlock Text="{Binding CategoryLabel}"
                                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="10"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Grid.Row="2" Spacing="8" Padding="12,8,12,16">
                    <Button Content="+ New Request" Click="AddRequest_Click"
                            HorizontalAlignment="Stretch"
                            Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource AccentBrush}"
                            CornerRadius="8" Padding="12,8"/>
                    <Button Content="Load OCC Templates" Click="LoadOccTemplates_Click"
                            HorizontalAlignment="Stretch"
                            Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource TextSecondaryBrush}"
                            CornerRadius="8" Padding="12,6" FontSize="11"/>
                    <Button Content="Load HAC / Solr Templates" Click="LoadHacTemplates_Click"
                            HorizontalAlignment="Stretch"
                            Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource TextSecondaryBrush}"
                            CornerRadius="8" Padding="12,6" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Request editor + response -->
        <Grid Grid.Column="1">
            <StackPanel x:Name="ApiEmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <FontIcon Glyph="&#xE8E9;" FontSize="40" FontFamily="Segoe Fluent Icons"
                          Foreground="{ThemeResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="Select or create a request"
                           Foreground="{ThemeResource TextSecondaryBrush}" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>

            <Grid x:Name="ApiEditorPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="220"/>
                </Grid.RowDefinitions>

                <!-- Name + category row -->
                <Border Grid.Row="0" Background="{ThemeResource SurfaceBrush}"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="16,10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBox x:Name="ReqNameBox" PlaceholderText="Request name" MinWidth="200"
                                 Background="{ThemeResource SurfaceBrush}"
                                 Foreground="{ThemeResource TextPrimaryBrush}"
                                 BorderBrush="{ThemeResource BorderBrush}" CornerRadius="8"/>
                        <ComboBox x:Name="ReqCategoryPicker" MinWidth="120"
                                  Background="{ThemeResource SurfaceBrush}"
                                  Foreground="{ThemeResource TextPrimaryBrush}"
                                  BorderBrush="{ThemeResource BorderBrush}">
                            <ComboBoxItem Content="OCC"/>
                            <ComboBoxItem Content="HAC"/>
                            <ComboBoxItem Content="Jira"/>
                            <ComboBoxItem Content="Linear"/>
                            <ComboBoxItem Content="Custom"/>
                        </ComboBox>
                        <Button Content="Save" Click="SaveRequest_Click"
                                Background="#A78BFA" Foreground="White" CornerRadius="8" Padding="14,6"/>
                        <Button Content="Delete" Click="DeleteRequest_Click"
                                Background="#3F1A1A" Foreground="#F87171" CornerRadius="8" Padding="12,6"/>
                    </StackPanel>
                </Border>

                <!-- URL bar -->
                <Grid Grid.Row="1" Margin="16,12,16,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0" x:Name="ReqMethodPicker" MinWidth="90"
                              Background="{ThemeResource SurfaceBrush}"
                              Foreground="{ThemeResource TextPrimaryBrush}"
                              BorderBrush="{ThemeResource BorderBrush}"
                              CornerRadius="8,0,0,8" Margin="0,0,-1,0">
                        <ComboBoxItem Content="GET" Tag="GET"/>
                        <ComboBoxItem Content="POST" Tag="POST"/>
                        <ComboBoxItem Content="PUT" Tag="PUT"/>
                        <ComboBoxItem Content="PATCH" Tag="PATCH"/>
                        <ComboBoxItem Content="DELETE" Tag="DELETE"/>
                    </ComboBox>
                    <TextBox Grid.Column="1" x:Name="ReqUrlBox"
                             PlaceholderText="https://example.com/occ/v2/electronics/products/300938"
                             Background="{ThemeResource SurfaceBrush}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             BorderBrush="{ThemeResource BorderBrush}"
                             CornerRadius="0" FontFamily="Consolas" FontSize="12"/>
                    <Button Grid.Column="2" Content="Send" Click="SendRequest_Click"
                            Background="#A78BFA" Foreground="White"
                            CornerRadius="0,8,8,0" Padding="20,10"/>
                </Grid>

                <!-- Headers -->
                <StackPanel Grid.Row="2" Margin="16,8,16,4" Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="HEADERS" Foreground="{ThemeResource TextSecondaryBrush}"
                                   FontSize="10" FontWeight="SemiBold" CharacterSpacing="150" VerticalAlignment="Center"/>
                        <Button Content="🔑 Auto Auth" Click="AutoAuth_Click"
                                Background="#252535" Foreground="#10B981"
                                CornerRadius="6" Padding="8,3" FontSize="10"
                                VerticalAlignment="Center" ToolTipService.ToolTip="Populate auth from active environment credentials"/>
                    </StackPanel>
                    <TextBox x:Name="ReqHeadersBox"
                             PlaceholderText="Authorization: Bearer TOKEN&#x0A;Content-Type: application/json"
                             AcceptsReturn="True" Height="60" TextWrapping="Wrap"
                             Background="{ThemeResource SurfaceBrush}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             BorderBrush="{ThemeResource BorderBrush}"
                             FontFamily="Consolas" FontSize="11"
                             CornerRadius="8" Padding="10"/>
                </StackPanel>

                <!-- Body -->
                <StackPanel Grid.Row="3" Margin="16,4,16,8" Spacing="6">
                    <TextBlock Text="BODY (JSON)" Foreground="{ThemeResource TextSecondaryBrush}"
                               FontSize="10" FontWeight="SemiBold" CharacterSpacing="150"/>
                    <TextBox x:Name="ReqBodyBox"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="80"
                             Background="{ThemeResource SurfaceBrush}"
                             Foreground="{ThemeResource TextPrimaryBrush}"
                             BorderBrush="{ThemeResource BorderBrush}"
                             FontFamily="Consolas" FontSize="11"
                             CornerRadius="8" Padding="10"/>
                </StackPanel>

                <!-- Response status bar -->
                <Border Grid.Row="4" Padding="16,8"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,1,0,1"
                        Background="{ThemeResource SurfaceVariantBrush}">
                    <Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="RESPONSE" Foreground="{ThemeResource TextSecondaryBrush}"
                                       FontSize="10" FontWeight="SemiBold" CharacterSpacing="150" VerticalAlignment="Center"/>
                            <TextBlock x:Name="RespStatusText" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock x:Name="RespDurationText" Foreground="{ThemeResource TextSecondaryBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                            <Border Width="1" Height="16" Background="{ThemeResource BorderBrush}" Margin="4,0"/>
                            <!-- Response sub-tabs -->
                            <Button x:Name="RespTabBody" Content="Body" Tag="Body" Click="RespTab_Click"
                                    Background="{ThemeResource ListAccentLowBrush}" Foreground="{ThemeResource TextPrimaryBrush}"
                                    CornerRadius="6" Padding="10,3" FontSize="11"/>
                            <Button x:Name="RespTabHeaders" Content="Headers" Tag="Headers" Click="RespTab_Click"
                                    Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                    CornerRadius="6" Padding="10,3" FontSize="11"/>
                            <Button x:Name="RespTabHistory" Content="History" Tag="History" Click="RespTab_Click"
                                    Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                    CornerRadius="6" Padding="10,3" FontSize="11"/>
                            <Button x:Name="RespTabCompare" Content="Compare" Tag="Compare" Click="RespTab_Click"
                                    Background="Transparent" Foreground="{ThemeResource TextSecondaryBrush}"
                                    CornerRadius="6" Padding="10,3" FontSize="11"/>
                        </StackPanel>
                        <Button Content="Copy" Click="CopyResponse_Click"
                                HorizontalAlignment="Right"
                                Background="Transparent" Foreground="{ThemeResource AccentBrush}"
                                BorderThickness="0" Padding="8,4" FontSize="11"/>
                    </Grid>
                </Border>

                <!-- Response panels -->
                <Grid Grid.Row="5">
                    <!-- Body panel -->
                    <ScrollViewer x:Name="RespBodyPanel" HorizontalScrollBarVisibility="Auto">
                        <TextBox x:Name="RespBodyBox"
                                 IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                 Background="{ThemeResource SurfaceBrush}"
                                 Foreground="{ThemeResource TextPrimaryBrush}"
                                 BorderThickness="0"
                                 FontFamily="Consolas" FontSize="11"
                                 Padding="16"/>
                    </ScrollViewer>

                    <!-- Headers panel -->
                    <ScrollViewer x:Name="RespHeadersPanel" Visibility="Collapsed" HorizontalScrollBarVisibility="Auto">
                        <TextBox x:Name="RespHeadersBox"
                                 IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                 Background="{ThemeResource SurfaceBrush}"
                                 Foreground="{ThemeResource TextPrimaryBrush}"
                                 BorderThickness="0"
                                 FontFamily="Consolas" FontSize="11"
                                 Padding="16"/>
                    </ScrollViewer>

                    <!-- History panel -->
                    <ScrollViewer x:Name="RespHistoryPanel" Visibility="Collapsed">
                        <StackPanel x:Name="HistoryContainer" Spacing="0" Padding="0"/>
                    </ScrollViewer>

                    <!-- Compare panel -->
                    <Grid x:Name="RespComparePanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Padding="16,8" Background="{ThemeResource SurfaceBrush}"
                                BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Run A:" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center"/>
                                <ComboBox x:Name="ComparePickerA" MinWidth="200"
                                          Background="{ThemeResource SurfaceBrush}" Foreground="{ThemeResource TextPrimaryBrush}"
                                          BorderBrush="{ThemeResource BorderBrush}" FontSize="11"
                                          SelectionChanged="ComparePicker_SelectionChanged"/>
                                <TextBlock Text="Run B:" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                <ComboBox x:Name="ComparePickerB" MinWidth="200"
                                          Background="{ThemeResource SurfaceBrush}" Foreground="{ThemeResource TextPrimaryBrush}"
                                          BorderBrush="{ThemeResource BorderBrush}" FontSize="11"
                                          SelectionChanged="ComparePicker_SelectionChanged"/>
                            </StackPanel>
                        </Border>
                        <ScrollViewer Grid.Row="1">
                            <StackPanel x:Name="CompareResultContainer" Padding="16" Spacing="4"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
