<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QAssistant.Views.EnvironmentsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationBackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar: environment list -->
        <Border Grid.Column="0" Background="{ThemeResource SurfaceBrush}"
                BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="12,12,8,8"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel Spacing="4">
                        <TextBlock Text="ENVIRONMENTS" Foreground="{ThemeResource TextSecondaryBrush}"
                                   FontSize="9" FontWeight="SemiBold" CharacterSpacing="180"/>
                        <TextBlock Text="Per-project endpoint registry" Foreground="{ThemeResource TextSecondaryBrush}"
                                   FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="4" Padding="8,8">
                        <ListView x:Name="EnvList" Background="Transparent"
                                  SelectionMode="Single" SelectionChanged="EnvList_SelectionChanged">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,2"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <ListViewItemPresenter
                                                    SelectedBackground="{ThemeResource ListAccentLowBrush}"
                                                    SelectedForeground="{ThemeResource TextPrimaryBrush}"
                                                    SelectedPressedBackground="{ThemeResource ListAccentMediumBrush}"
                                                    SelectedPointerOverBackground="{ThemeResource ListAccentMediumBrush}"
                                                    PointerOverBackground="{ThemeResource HoverBrush}"
                                                    PressedBackground="{ThemeResource BorderBrush}"
                                                    CornerRadius="6" ContentMargin="10,7"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="4" Height="16" CornerRadius="2"
                                                Background="{Binding ColorBrushDisplay}" Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <TextBlock Text="{Binding Name}" Foreground="{ThemeResource TextPrimaryBrush}" FontSize="12"/>
                                            <TextBlock Text="{Binding TypeLabel}" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                                        </StackPanel>
                                        <!-- Health status dot -->
                                        <Ellipse Grid.Column="2" Width="8" Height="8" Margin="4,0"
                                                 Fill="{Binding HealthBrush}"/>
                                        <FontIcon Grid.Column="3" Glyph="&#xE735;" FontSize="10"
                                                  FontFamily="Segoe Fluent Icons" Foreground="#10B981"
                                                  Visibility="{Binding DefaultBadgeVisibility}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="2" Spacing="6" Margin="8,4,8,12">
                    <Button Content="Check All Endpoints" Click="CheckAllHealth_Click"
                            HorizontalAlignment="Stretch"
                            Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource TextPrimaryBrush}"
                            CornerRadius="8" Padding="10,7"/>
                    <Button Content="+ Add Environment" Click="AddEnv_Click"
                            HorizontalAlignment="Stretch"
                            Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource AccentBrush}"
                            CornerRadius="8" Padding="10,7"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Detail / editor panel -->
        <Grid Grid.Column="1">

            <!-- Empty state -->
            <StackPanel x:Name="EnvEmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <FontIcon Glyph="&#xE909;" FontSize="40" FontFamily="Segoe Fluent Icons"
                          Foreground="{ThemeResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                <TextBlock Text="Select or add an environment" Foreground="{ThemeResource TextSecondaryBrush}"
                           FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Editor -->
            <ScrollViewer x:Name="EnvEditorPanel" Visibility="Collapsed" Padding="24">
                <StackPanel Spacing="20" MaxWidth="600">

                    <!-- Env name + type row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="Name" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                            <TextBox x:Name="EnvNameBox" PlaceholderText="e.g. Staging"
                                     Background="{ThemeResource SurfaceBrush}"
                                     Foreground="{ThemeResource TextPrimaryBrush}"
                                     BorderBrush="{ThemeResource BorderBrush}" CornerRadius="8"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock Text="Type" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                            <ComboBox x:Name="EnvTypePicker" HorizontalAlignment="Stretch"
                                      Background="{ThemeResource SurfaceBrush}"
                                      Foreground="{ThemeResource TextPrimaryBrush}"
                                      BorderBrush="{ThemeResource BorderBrush}">
                                <ComboBoxItem Content="Development" Tag="Development"/>
                                <ComboBoxItem Content="Staging" Tag="Staging"/>
                                <ComboBoxItem Content="Production" Tag="Production"/>
                                <ComboBoxItem Content="Custom" Tag="Custom"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Base URL -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Base URL" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBox x:Name="EnvBaseUrlBox" PlaceholderText="https://example.com"
                                 Background="{ThemeResource SurfaceBrush}"
                                 Foreground="{ThemeResource TextPrimaryBrush}"
                                 BorderBrush="{ThemeResource BorderBrush}" CornerRadius="8"/>
                    </StackPanel>

                    <!-- Health Check URL -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Health Check URL (optional, falls back to Base URL)" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBox x:Name="EnvHealthCheckUrlBox" PlaceholderText="https://example.com/health"
                                 Background="{ThemeResource SurfaceBrush}"
                                 Foreground="{ThemeResource TextPrimaryBrush}"
                                 BorderBrush="{ThemeResource BorderBrush}" CornerRadius="8"/>
                    </StackPanel>

                    <!-- SAP Commerce section -->
                    <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="10"
                            Padding="16" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock Text="SAP COMMERCE ENDPOINTS" Foreground="{ThemeResource TextSecondaryBrush}"
                                       FontSize="10" FontWeight="SemiBold" CharacterSpacing="150"/>
                            <StackPanel Spacing="6">
                                <TextBlock Text="HAC URL" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBox x:Name="EnvHacUrlBox" PlaceholderText="https://example.com/hac"
                                         Background="{ThemeResource SurfaceBrush}"
                                         Foreground="{ThemeResource TextPrimaryBrush}"
                                         BorderBrush="{ThemeResource BorderBrush}" CornerRadius="8"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Backoffice URL" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBox x:Name="EnvBackofficeUrlBox" PlaceholderText="https://example.com/backoffice"
                                         Background="{ThemeResource SurfaceBrush}"
                                         Foreground="{ThemeResource TextPrimaryBrush}"
                                         BorderBrush="{ThemeResource BorderBrush}" CornerRadius="8"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Storefront URL" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBox x:Name="EnvStorefrontUrlBox" PlaceholderText="https://example.com/storefront"
                                         Background="{ThemeResource SurfaceBrush}"
                                         Foreground="{ThemeResource TextPrimaryBrush}"
                                         BorderBrush="{ThemeResource BorderBrush}" CornerRadius="8"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Solr Admin URL" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBox x:Name="EnvSolrUrlBox" PlaceholderText="https://example.com:8983/solr"
                                         Background="{ThemeResource SurfaceBrush}"
                                         Foreground="{ThemeResource TextPrimaryBrush}"
                                         BorderBrush="{ThemeResource BorderBrush}" CornerRadius="8"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="OCC Base Path" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBox x:Name="EnvOccPathBox" PlaceholderText="/occ/v2"
                                         Background="{ThemeResource SurfaceBrush}"
                                         Foreground="{ThemeResource TextPrimaryBrush}"
                                         BorderBrush="{ThemeResource BorderBrush}" CornerRadius="8"/>
                            </StackPanel>
                            <Border Height="1" Background="{ThemeResource BorderBrush}" Margin="0,4,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,12,0">
                                    <TextBlock Text="Ignore SSL Errors"
                                               Foreground="{ThemeResource TextPrimaryBrush}" FontSize="13"/>
                                    <TextBlock Text="Bypass certificate validation for self-signed certificates. Development environments only — never enable for production."
                                               Foreground="#F59E0B" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="EnvIgnoreSslToggle" Grid.Column="1"
                                             VerticalAlignment="Center" OnContent="" OffContent=""/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- HAC Credentials -->
                    <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="10"
                            Padding="16" BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="12">
                            <TextBlock Text="HAC CREDENTIALS" Foreground="{ThemeResource TextSecondaryBrush}"
                                       FontSize="10" FontWeight="SemiBold" CharacterSpacing="150"/>
                            <TextBlock Text="Stored securely in Windows Credential Manager"
                                       Foreground="{ThemeResource TextSecondaryBrush}" FontSize="11"/>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Username" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                                <TextBox x:Name="EnvUsernameBox" PlaceholderText="admin"
                                         Background="{ThemeResource SurfaceBrush}"
                                         Foreground="{ThemeResource TextPrimaryBrush}"
                                         BorderBrush="{ThemeResource BorderBrush}" CornerRadius="8"/>
                            </StackPanel>
                            <StackPanel Spacing="6">
                                <TextBlock Text="Password" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                                <PasswordBox x:Name="EnvPasswordBox" PlaceholderText="••••••••"
                                             Background="{ThemeResource SurfaceBrush}"
                                             Foreground="{ThemeResource TextPrimaryBrush}"
                                             BorderBrush="{ThemeResource BorderBrush}" CornerRadius="8"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Notes -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="Notes" Foreground="{ThemeResource TextSecondaryBrush}" FontSize="12"/>
                        <TextBox x:Name="EnvNotesBox" PlaceholderText="Any notes about this environment..."
                                 AcceptsReturn="True" Height="80" TextWrapping="Wrap"
                                 Background="{ThemeResource SurfaceBrush}"
                                 Foreground="{ThemeResource TextPrimaryBrush}"
                                 BorderBrush="{ThemeResource BorderBrush}" CornerRadius="8" Padding="10"/>
                    </StackPanel>

                    <!-- Default toggle -->
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <CheckBox x:Name="EnvDefaultCheck" Content="Set as default environment"
                                  Foreground="{ThemeResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <!-- Action buttons -->
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Save" Click="SaveEnv_Click"
                                    Background="{ThemeResource AccentBrush}" Foreground="White"
                                    CornerRadius="8" Padding="10,7"/>
                            <Button x:Name="SwitchActiveBtn" Content="Switch Active" Click="SwitchActive_Click"
                                    Background="#1A3A2A" Foreground="#10B981"
                                    CornerRadius="8" Padding="10,7"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="TestConnBtn" Content="Test Connection" Click="TestConn_Click"
                                    Background="{ThemeResource HoverBrush}" Foreground="{ThemeResource AccentBrush}"
                                    CornerRadius="8" Padding="10,7"/>
                            <Button x:Name="DeleteEnvBtn" Content="Delete" Click="DeleteEnv_Click"
                                    Background="#3F1A1A" Foreground="#F87171"
                                    CornerRadius="8" Padding="10,7"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock x:Name="EnvStatusText" Foreground="{ThemeResource TextSecondaryBrush}"
                               FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
